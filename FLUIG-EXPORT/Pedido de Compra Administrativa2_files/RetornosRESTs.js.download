function filtroFornecedor() {
	console.log("filtro Fornecedor")
	var urlCodigo
	var activity = WKNumState;
	//var pesquisaFornecedor = $("#PesquisaFornecPor").val();
	var fornecedor = $("#fornecedorC").val();
	var pesquisaLiberada = $("#liberado").val();

	//urlCodigo = "https://winthorapi.ddlabs.com.br/produtos/consultar.php?token=MTUwODIwMTk6UFJPRDoxNzQ1NzQwNDAwMTM0NQ==&pesquisar=&";
	urlCodigo = "/api/public/ecm/dataset/search?datasetId=dsConsultaFornecedoresRestCONSINCO&searchField=Descricao&";
	
	//urlCodigo = "https://winthorapi.ddlabs.com.br/produtos/consultar.php?token=MTUwODIwMTk6UFJPRDoxNzQ1NzQwNDAwMTM0NQ==&pesquisar=coca&";
	console.log()
	var Fornecedorsettings = {
		source: {
			url: urlCodigo + '',
			/*
			 * Também poderia ser informada a URL completa:
			 * 'http://{host}:{port}/api/public/ecm/dataset/search?datasetId=colleague&searchField=colleagueName&'
			 * É importante manter o "&" no final da URL, pois os outros
			 * parâmetros são montados sem levar em consideração que já possa
			 * haver algo parametrizado no próprio link
			 */
			contentType: 'application/json',
			root: 'content',
			pattern: '',
			limit: 10,
			offset: 0,
			patternKey: 'searchValue',
			/*
			 * Para que a consulta funcione, é importante que o valor do
			 * 'patternKey' seja sempre 'searchValue' para o caso de zoom de
			 * dataset
			 */
			limitkey: 'limit',
			offsetKey: 'offset'
		},
		displayKey: 'CodDescricaoCGC',
		/*
		 * Para o dataset de colleague optamos por mostrar o nome completo. É
		 * aconselhável escolher o campo que, sozinho, represente melhor o
		 * registro
		 */

		
	};

	//trava da consulta via API
	
	if (activity == 240 ||activity == 93 ||activity == 225 ||activity == 111||activity == 206||activity == 181||activity == 5 ||activity == 18 ) {
		if (pesquisaLiberada=="liberado"){
	   var FornecedorFilter = FLUIGC.filter('#fornecedorC', Fornecedorsettings);
		}

	}



	FornecedorFilter.on('fluig.filter.item.added', function (data) {

		$("#codCNPJ").val(data.item.CGC);
		$("#fornecedor").val(data.item.CodDescricao);
	});

}

