WCMC.tabview=function(cfg){if($.type(cfg)==="string"){cfg={container:cfg}}var events=[];var idTabview=WCMAPI.generateId();var config={};var tab_counter=0;var tab_index=0;var tabs=[];var renderHtml=undefined;var divTabs=undefined;var jTab=undefined;var merge=function(defaults){config=$.extend(defaults,cfg);if(config.container!=undefined){config.container="#"+config.container}};var defaults={container:"body",close:false,sortable:false,tabs:{},modeHtml:false};merge(defaults);var functions=$({bind:function(name,func){if($.inArray(name,events)>-1){func()}functions.bind(name,func)},addTab:function(tab){if(tab){var jTabs=divTabs.tabs();var ul=jTab.find("ul")[0];var tabId="tabs-"+cfg.container+"-"+tab_counter;$("<li><a href='#"+tabId+"'>"+tab.label+"</a></li>").appendTo(ul);var panel=$("<div id='"+tabId+"'></div>");if(!tab.tab_url&&tab.content){panel.append(tab.content)}$("<div id='"+tabId+"'>"+panel.html()+"</div>").appendTo(jTabs);jTabs.tabs("refresh");tab.index=tab_index;tabs.push(tab);if(tab.active!=undefined&&tab.active!=null&&tab.active==true){functions[0]["selectTab"](tab_index);var tab_url_temp=tab.url;panel=$("#"+tabId);if(tab_url_temp!=undefined&&panel.html()==""){extractHtml(tab_url_temp,tab.callBack,tab.extractJS,panel);renderHtml=undefined}}functions.trigger("tabview-add-tab",tab);tab_counter++;tab_index++}},addTabs:function(tabs){if(tabs&&$.isArray(tabs)){for(var i=0;i<tabs.length;i++){functions[0]["addTab"](tabs[i])}}},selectTab:function(index){divTabs.tabs("option","active",index)},getSize:function(){return jTab.find(">ul >li").length},removeTab:function(index){jTab.tabs("remove",index);tabs.splice(index,1);tab_index--;functions.trigger("tabview-remove-tab")},removeAllTabs:function(){while(functions[0]["getSize"]()!=0){functions[0]["removeTab"](0)}},getTabSelected:function(){return tabs[parseInt(jTab.tabs("option","selected"))]},getTab:function(index){return tabs[index]}});var createTabview=function(){if(config.modeHtml!=undefined&&config.modeHtml!=null&&config.modeHtml===true){divTabs=$(config.container);divTabs.tabs({})}else{divTabs=$("<div>");divTabs.attr("id",idTabview);divTabs.html($("<ul>"));$(config.container).html(divTabs);if(config.close){var strHref="{href}";var strLabel="{label}";divTabs.tabs({tabTemplate:"<li><a href='#"+strHref+"'>#"+strLabel+"</a> <span class='ui-icon ui-icon-close'>Remove Tab</span></li>"});$("#"+idTabview+" span.ui-icon-close").on("click",function(){var tabHref=$(this).parent().find("a").attr("href");var contentTab=$("#"+idTabview+" "+tabHref);var index=$("#"+idTabview+" div").index(contentTab);jTab.tabs("remove",index)})}if(config.tabs!=undefined&&config.tabs!=null&&$.isArray(config.tabs)){for(var i=0;i<config.tabs.length;i++){var tab=config.tabs[i];functions[0]["addTab"](tab.label,tab.content)}}}if(config.sortable){divTabs.tabs().find(".ui-tabs-nav").sortable({axis:"x",stop:function(event,ui){divTabs.tabs("refresh");functions.trigger("tabview-tab-sortable-update")}})}jTab=$("#"+idTabview)};var addEvents=function(){divTabs.tabs({activate:function(event,ui){var index=jTab.tabs("option","active");var tab_temp=null;if(config.modeHtml===false){tab_temp=tabs[index];var tab_url_temp=tab_temp.url;var panel=$(ui.newPanel);if(tab_url_temp&&panel.html()==""){var extractJS=tab_temp.extractJS;extractHtml(tab_url_temp,tab_temp.callBack,extractJS,panel)}}else{tab_temp={index:index}}functions.trigger("tabview-tab-selected-change",tab_temp)}})};var extractHtml=function(tab_url_temp,tab_callBack,extractJS,panel){if(extractJS==undefined){extractJS=true}if(tab_url_temp!=null&&tab_url_temp!=undefined){var urlPath=tab_url_temp.substr(0,tab_url_temp.lastIndexOf("/"));var appCode=urlPath.substr(urlPath.lastIndexOf("/")+1,urlPath.length);urlPath+="/";var nameFile=tab_url_temp.substr(tab_url_temp.lastIndexOf("/")+1,tab_url_temp.length);var ext=nameFile.substr(nameFile.length-4,nameFile.length);if(ext.toLowerCase()===".ftl"){WCMAPI.convertFtl(appCode,nameFile,undefined,panel,tab_callBack)}else{renderHtml=WCMAPI.syncAjax(tab_url_temp);if(extractJS){extractScriptsAndCss(renderHtml,urlPath,null);if(scripts){for(i=0;i<scripts.length;i++){WCMAPI.loadJS(scripts[i],tab_callBack)}}}}}};var extractCss=function(html,url){var attr=/(\w+)(?:\s*=\s*(?:(?:"((?:\\.|[^"])*)")|(?:'((?:\\.|[^'])*)')|([^>\s]+)))?/g;var styles=new Array();while(html){var index=html.indexOf("<link");var match;var css;var fullCss;var temp;if(index==-1){break}else{html=html.substr(index);match=html.match("/>");fullCss=css=html.substr(0,match.index);temp=css.match(attr);for(j=0;j<temp.length;j++){if(temp[j].substr(0,4)=="href"){css=temp[j].substr(6);css=css.substr(0,css.indexOf('"'));if(url!=null&&url!=undefined){css=url+css}styles.push(css)}}renderHtml=renderHtml.replace(fullCss+"/>","");html=html.substr(match.index)}}if(styles){for(i=0;i<styles.length;i++){WCMAPI.loaderCss(styles[i])}}};var scripts=new Array();var extractScriptsAndCss=function(html,url,callBack){scripts=new Array();var attr=/(\w+)(?:\s*=\s*(?:(?:"((?:\\.|[^"])*)")|(?:'((?:\\.|[^'])*)')|([^>\s]+)))?/g;renderHtml=html;while(html){var index=html.indexOf("<script");var match;var script;var fullScript;var temp;if(index==-1){break}else{html=html.substr(index);match=html.match("<\/script>");fullScript=script=html.substr(0,match.index);temp=script.match(attr);for(j=0;j<temp.length;j++){if(temp[j].substr(0,3)=="src"){script=temp[j].substr(5);script=script.substr(0,script.indexOf('"'));if(url!=null&&url!=undefined){script=url+script}scripts.push(script)}}renderHtml=renderHtml.replace(fullScript+"<\/script>","");html=html.substr(match.index)}}extractCss(renderHtml,url)};createTabview();addEvents();functions.trigger("tabview-load");events.push("tabview-load");return functions[0]};