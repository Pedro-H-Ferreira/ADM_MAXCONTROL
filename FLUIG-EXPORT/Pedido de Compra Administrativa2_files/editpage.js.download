function currentUrlWithoutEdit(){return window.location.pathname.replace("edit=true","")}function currentUrlWithEdit(){var currentUrl=currentUrlWithoutEdit();return currentUrl+"?edit=true"}$(function(){$.ajaxSetup({cache:false});var locale=window.WCMAPI?window.WCMAPI.getLocale():"pt_BR";var i18n={pt_BR:{modalTitle:"Editando P\u00E1ginas",modalDescription:"Voc\u00EA n\u00E3o foi o \u00FAltimo usu\u00E1rio a editar esta p\u00E1gina. Voc\u00EA quer continuar com a edi\u00E7\u00E3o deste rascunho?",modalYes:"Sim",modalNo:"Não",},en_US:{modalTitle:"Editing Pages",modalDescription:"You were not the last user to edit this page. Do you wish to continue editing this draft?",modalYes:"Yes",modalNo:"No"},es:{modalTitle:"Editando P\u00E1ginas",modalDescription:"Usted no fue el \u00FAltimo usuario en editar esta p\u00E1gina. \u00BFDesea continuar con la edici\u00F3n de este borrador?",modalYes:"S\u00ED",modalNo:"No"}}[locale];var wcmEditMode=$("#wcm-edit-mode").val();if(wcmEditMode==="true"){wcmEditMode=true}else{wcmEditMode=false}WCM.layout={};WCM.layout.hiddenEmptySlotFields=function(){var rootIds=$(".editable-slot");if(rootIds.length){var slotFullIsEmpty=false;rootIds.each(function(index,data){var rootId=data.id;var isAllEmpty=true;$(data).children().each(function(pos,elem){if($(elem).children().length===0){$(elem).attr("style","display: none")}else{isAllEmpty=false}});if(isAllEmpty){$(data).hide()}})}};if(!wcmEditMode){WCM.layout.hiddenEmptySlotFields()}WCM.editPage=Object();WCM.editPage.concurrency=function(){var cfg={width:380,height:130,maximized:false,title:i18n.modalTitle,bodyContent:i18n.modalDescription,showbtclose:false,showCloseIcon:false,customButtons:[i18n.modalYes,i18n.modalNo]};WCM.editPage.concurrency.panel=WCMC.panel(cfg);WCM.editPage.concurrency.panel.bind("panel-button-1",function(){WCM.editPage.concurrency.panel.close();window.location.href=currentUrlWithoutEdit()})}});$(document).ready(function(){$(".wcm_config_widgets").on("click",function(){$(this).parent("li").children("ul").toggle()});$(document).bind("click",function(e){var $clicked=$(e.target);if(!$clicked.parents().hasClass("wcm_controles_widgets")){$(".wcm_controles_widgets ul li ul").hide()}})});