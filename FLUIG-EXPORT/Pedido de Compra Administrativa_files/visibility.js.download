var aprovarCotacao = 245;
var realizarCompra = 255;
var anexarNF = 240;
var fim = 11;
var fim2 = 68;



$(document).ready(function (obj) {
//$(document).on("ready",function (obj){

    initAtv();
    view();

    if(mobaiu == 'S'){
        viewMobile();
    }
    
  //Nova regra para inclusão da cotação  
    $('#idAnalisarRadioCompra').on('click', function() {
  	  console.log("Bloquear o painel da cotação");
      adicionarCotacao();
    });

    //Atualiza numero da solicitação
    if(AprovGestor == numProcess){
        setaValor("numeroSolicitacao",WKNumProces)
    }
    
    $("#idradiorateioNF").click(function(){
        console.log("Boqueio do painel de Rateio");
        showCamposRateio();
    });
    //Regra para o XML
    $("#idradioParcelasNF").click(function(){
        console.log("Boqueio do painel do XML");
        showCamposParcelas();
    });    
    //Regra para o XML upload
    $("#idFileUpload").click(function(){
        console.log("Boqueio do painel os campos Filial e Fornecedor");
        showCamposBloqueadosXML();
    }); 
    //Verificar o preenchimento de funcionario ou fornecedor  
    $("#idDefinirNF").click(function(){
        console.log("Boqueio do painel de Funcionario e Fornecedor");
        showCamposDefinir();
    });     
    
    $("#idRadioLancaInputNF").click(function(){
        console.log("Boqueio do painel de Solicitação de Ajuste");
        showCamposCentral();
    });
    
    $("#idRadioPagamentoRealizado").click(function(){
        console.log("Liberar o campo demanda para finaceiro");
        showDemandaFinanceiro();
    });
    
    $("#idDescricaoDemandaEnvio").click(function(){
        console.log("Liberar o campo Carregamento");
        showCamposCarregamento();
    });
    
    $("#idNF").click(function(){
        console.log("Liberar o campo Carregamento");
        showCamposCarregamento();
    });
  
    $("#topBtn").click(function(){
        console.log("Liberar o campo Carregamento");
        showCamposCarregamento();
    });
    
    
    
    //Função de visualizar a data
    var numProcess = WKNumProces;
    if(numProcess == inicio){
	$.each($("[data-date]"), function(i, o) {
        var id = $(o).attr("id");
		FLUIGC.calendar("#" + id);
	});

    } 

    
    
});

//Realiza ações funcionais
function initAtv() {

    var atividade = WKNumState;
    
    if ( atividade == inicio || atividade == inicio1 ) {
        initCargo();
        initFluigCalendar();
    }    
    
    
    
}

//Mostra, oculta, bloqueia e libera campos
function view() {
    var atividade = WKNumState;

    
    
    
    //bloqueios
    if(atividade != inicio && atividade != inicio1 &&  atividade != realizarAjusteGestor && atividade != corrigirProblemaPublicacao && atividade != providenciarAjustes && atividade != providenciarAjustesAtraso && atividade !=  realizarAjusteFinanceiro && atividade !=  realizarAjusteControladoria && atividade !=  realizarAjusteGerenteRegional && atividade !=  realizarAjustePresidente){
        protege("#accordionCabecalhoPedido")
        protege("#solAccordionProdutos")
        
        
    }
    //Novas atividades
    if(atividade != aprovacaoGestorImediato){
        protege("#accordionAreaGestorImediato")
    }
    
    if(atividade != analisaCotar){
        protege("#accordionProdutosCompras")
        protege("#accordionProdutos")
    }
    
    if(atividade != aprovarCotacao){
        protege("#accordionGestaoCompra")
    }
    
    if(atividade != realizarCompra){
