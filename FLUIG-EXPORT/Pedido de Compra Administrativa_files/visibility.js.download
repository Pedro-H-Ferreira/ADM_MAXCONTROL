function adicionarCotacao(){
	var tag = 'adicionarCotacao() ->';
	var atividade = WKNumState;
	    // Verificando o seleção do Produto
	if(atividade == 242){
	    var painel = $('input[name=analisarRadioCompra]:checked').val();
	    if ( painel == "sim" ) {
	        $("#idPanelProdutos").hide();
	        //$("#valorNFProdutoR").show();
	        
	    } 
	    if ( painel == "nao" ) {
	        $("#idPanelProdutos").show();
	        //$("#valorNFProdutoR").hide();
	    }
}
}

