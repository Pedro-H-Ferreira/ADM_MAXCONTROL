function showCamposRateio(){
    // Verificando o seleção do rateio
    var rateioNF = $('input[name=radiorateioNF]:checked').val();
    if ( rateioNF == "sim" ) {
        $("#painelRateioNF").show();
        $("#valorNFRateioR").show();
        
    } else {
        $("#painelRateioNF").hide();
        $("#valorNFRateioR").hide();
    }

}

function showCamposParcelas(){
    // Verificando o seleção do rateio
    var parcelasNF = $('input[name=radioParcelasNF]:checked').val();
    if ( parcelasNF == "sim" ) {
        $("#idpainelParcelasNF").show();
        
    } else {
        $("#idpainelParcelasNF").hide();

    }

}

function showCamposBloqueadosXML(){
    $("#unidadeFilial").attr('readonly', true);
    $("#fornecedorC").attr('readonly', true);
    $("#funcionarioC").attr('readonly', true);
    $("#nNotaFiscal").attr('readonly', true);
    $("#dataEmissaoNF").attr('readonly', true);
    $("#valorNF").attr('readonly', true);
}



function showCamposDefinir(){
    // Verificando o seleção do rateio
    var definirCF = $('input[name=definirNF]:checked').val();
    if ( definirCF == "fornecedor" ) {
        $("#idfornecedorC").show();
        $("#idfuncionarioC").hide();
       
        
    } else {
        $("#idfornecedorC").hide();
        $("#idfuncionarioC").show(); 
    }

}

function showCamposCentral(){
    // Verificando o seleção do rateio
    var camposCentral = $('input[name=radioLancaInputNF]:checked').val();
    if ( camposCentral == "nao" ) {
        $("#painelCabecalho").show();
        $("#painelLancaWinthor").hide();
        
    } else {
        $("#painelCabecalho").hide();
        $("#painelLancaWinthor").show();
    }

}

function showDemandaFinanceiro(){
