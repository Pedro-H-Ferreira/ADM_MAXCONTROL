var request = function request(config) {
  var xhr = new XMLHttpRequest();

  if ('onUploadProgress' in config) {
    xhr.upload.onprogress = config.onUploadProgress;
  }

  if ('onerror' in config) {
    xhr.onerror = config.onerror;
    xhr.upload.onerror = config.onerror;
  }

  if ('onUploadEnd' in config) {
    xhr.upload.onloadend = config.onUploadEnd;
  }

  xhr.onreadystatechange = function () {
    // if (!xhr || xhr.readyState !== 4) {
    //     return config.onerror();
    // }
    if ('callback' in config) {
      config.callback(xhr.response);
    } else {
      onloadEnd(xhr.response);
    }
  };

  xhr.open(config.method.toUpperCase(), config.url, true);
  xhr.send(config.data || null);
};



