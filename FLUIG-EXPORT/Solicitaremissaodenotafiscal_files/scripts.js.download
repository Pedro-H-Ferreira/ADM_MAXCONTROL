function setaValor(id,valor){
	$("#"+id).attr("value",valor)
    //document.getElementById(id).value = valor
}


function documentoDP01(obj) {
	
	var idPatrimonio = $("#codPatrimonio").val();
	var idNF = $("#filial").val();
    var nomeDocumento = " Nota Fiscal - "+idNF+ " - " +idPatrimonio;
    JSInterface.showCamera(nomeDocumento);
    top.document.getElementsByClassName("topBtn")[0].click();
} 

