var WCMBC=(function(WCMCropImage,$){WCMCropImage.cropImage=function(options,callback){var locale=WCMAPI.getLocale(),i18n;i18n={pt_BR:{"label.save":"Salvar","label.cancel":"Cancelar","label.title":"Editar imagem"},en_US:{"label.save":"Save","label.cancel":"Cancel","label.title":"Edit image"},es:{"label.save":"Guardar","label.cancel":"Cancelar","label.title":"Editar imagen"}}[locale];function init(){WCMAPI.addListener(this,"callbackcropimage",callbackcropimage);$(window).off("fluig.cropimage.save.callback").on("fluig.cropimage.save.callback",function(ev,data){if(typeof(options.saveCallback)==="function"){options.saveCallback(data)}});$(window).off("fluig.cropimage.cancel.callback").on("fluig.cropimage.cancel.callback",function(ev){if(typeof(options.cancelCallback)==="function"){options.cancelCallback()}});if(!options||typeof(options)!=="object"){options={}}if(!options.types){options.types="jpg|jpeg|png"}if(!options.alias){options.alias=WCMAPI.getUserLogin()}if(!options.imageShape){options.imageShape="default"}options.isSaveCallback=options.saveCallback?true:false;options.isCancelCallback=options.cancelCallback?true:false;showModal()}function showModal(){FLUIGC.modal({title:i18n["label.title"],size:"large",content:{widgetCode:"cropimage",ftl:"view.ftl",data:{customInstanceId:(new Date().getTime()).toString(),types:options.types,alias:options.alias,imageShape:options.imageShape,imageSrc:options.imageSrc?encodeURIComponent(options.imageSrc):null,urlService:options.urlService,isSaveCallback:options.isSaveCallback,isCancelCallback:options.isCancelCallback}},id:"fluig-modal-crop-image",actions:[{label:i18n["label.save"],bind:"data-save-crop-image",classType:"btn-primary btn-save-crop-image"},{label:i18n["label.cancel"],bind:"data-cancel-crop-image",actionClose:true}]})}function callbackcropimage(eventName,data){if(callback){if(data.status==="success"){return callback(null,data)}return callback(data,null)}}init()};return WCMCropImage})(window.WCMBC||{},jQuery);