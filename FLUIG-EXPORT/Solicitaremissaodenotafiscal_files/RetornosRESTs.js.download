
function filtroFilial() {
	console.log("filtro Filial")
	var urlCodigo
	//var pesquisaFilial = $("#PesquisaFornecPor").val();
	var filial = $("#filial").val();

	//urlCodigo = "https://winthorapi.ddlabs.com.br/produtos/consultar.php?token=MTUwODIwMTk6UFJPRDoxNzQ1NzQwNDAwMTM0NQ==&pesquisar=&";
	urlCodigo = "/api/public/ecm/dataset/search?datasetId=dsConsultaFilialDDRest&searchField=Descricao&";
	
	//urlCodigo = "https://winthorapi.ddlabs.com.br/produtos/consultar.php?token=MTUwODIwMTk6UFJPRDoxNzQ1NzQwNDAwMTM0NQ==&pesquisar=coca&";
	console.log()
	var Filialsettings = {
		source: {
			url: urlCodigo + '',
			/*
			 * Também poderia ser informada a URL completa:
			 * 'http://{host}:{port}/api/public/ecm/dataset/search?datasetId=colleague&searchField=colleagueName&'
			 * É importante manter o "&" no final da URL, pois os outros
			 * parâmetros são montados sem levar em consideração que já possa
			 * haver algo parametrizado no próprio link
			 */
			contentType: 'application/json',
			root: 'content',
			pattern: '',
			limit: 10,
			offset: 0,
			patternKey: 'searchValue',
			/*
			 * Para que a consulta funcione, é importante que o valor do
			 * 'patternKey' seja sempre 'searchValue' para o caso de zoom de
			 * dataset
			 */
			limitkey: 'limit',
			offsetKey: 'offset'
		},
		displayKey: 'CodDescricao',
		/*
		 * Para o dataset de colleague optamos por mostrar o nome completo. É
		 * aconselhável escolher o campo que, sozinho, represente melhor o
		 * registro
		 */

		
	};

	var FilialFilter = FLUIGC.filter('#filial', Filialsettings);




	FilialFilter.on('fluig.filter.item.added', function (data) {

		$("#coFilial").val(data.item.CodFilial);
	});

}
