var WCMMenu=SuperWidget.extend({MENU_MORE_CONTENT_CLASS:null,isPortalAdmin:null,currentPage:null,previousPage:null,controlPanelPage:null,hasMore:false,menuPages:null,removedPages:0,jMenuList:null,jMenuMore:null,jMenuMoreContainer:null,jMenuItem:null,CPANEL_ADMIN:"cpaneladmin",IMAGES:"images",VIDEOS:"videos",COMMUNITY:"community",init:function(){this.MENU_MORE_CONTENT_CLASS=".wcm-menu-more-content";this.setSessionAttribute("");this.loadCurrentPage()},getIconServlet:function(){return WCMAPI.getServerURL()+WCMAPI.getContextPath()+"/api/servlet/image/"},getPrefixUrl:function(){return WCMAPI.getServerURL()+WCMAPI.getServerContextURL()},loadMenus:function(){var self=this;if(self.isPortalAdmin===true){self.rest(WCMSpaceAPI.PageService.FINDPORTALADMINMENUPAGES,[self.currentPage.pageKey.id,window.location.pathname],function(data){self.loadHtmlMenus(data)})}else{self.rest(WCMSpaceAPI.PageService.FINDMENUPAGES,[self.currentPage.pageKey.id,window.location.pathname,WCMAPI.isEditMode],function(data){self.loadHtmlMenus(data)})}},getIconByPage:function(page){return this.getIconServlet()+WCMAPI.getTenantCode()+"/page/"+page.page+".png"},loadHtmlMenus:function(data){this.menuPages=data;this.jMenuList=$("#wcm-menu-list");if(this.menuPages){this.removedPages=0;for(var i=0;i<this.menuPages.content.length;i++){var page=this.menuPages.content[i];if(page.page===this.IMAGES||page.page===this.VIDEOS){this.removedPages++;continue}var submenu=document.createElement("div");if(this.hasChildren(page)===true){var divSub=document.createElement("div");divSub.className="submenu wcm-menu-background";var divSubIndicator=document.createElement("div");divSubIndicator.className="submenuindic";var divMenuMoreIndicatorTopLine=document.createElement("div");divMenuMoreIndicatorTopLine.className="wcm-menu-more-indicator-top-line";var divMenuMoreIndicatorTop=document.createElement("div");divMenuMoreIndicatorTop.className="wcm-menu-more-indicator-top wcm-menu-more-indicator-background-top";var divMenuMoreIndicatorBottomLine=document.createElement("div");divMenuMoreIndicatorBottomLine.className="wcm-menu-more-indicator-bottom-line";var divMenuMoreIndicatorBottom=document.createElement("div");divMenuMoreIndicatorBottom.className="wcm-menu-more-indicator-bottom wcm-menu-more-indicator-background-bottom";var divContent=document.createElement("div");divContent.className="submenucont";var ul=document.createElement("ul");if(page.children&&page.children.length>0){this.setColumnAmount(ul,page.children.length,8);for(var j=0;j<page.children.length;j++){var child=page.children[j],childMenuItem=Mustache.render(this.templates.tpl_child_menu_item,{hasChild:this.hasChildren(child)?"true":"false",href:this.getPrefixUrl()+child.uri,parentId:child.parentId,pageId:child.pageId,pageCode:child.page,title:child.title,});$(ul).append(childMenuItem)}}divSubIndicator.appendChild(divMenuMoreIndicatorTopLine);divSubIndicator.appendChild(divMenuMoreIndicatorTop);divSubIndicator.appendChild(divMenuMoreIndicatorBottomLine);divSubIndicator.appendChild(divMenuMoreIndicatorBottom);divSub.appendChild(divSubIndicator);divContent.appendChild(ul);divSub.appendChild(divContent);submenu.appendChild(divSub)}var divChildIndicator="";var hasChild="false";if(this.hasChildren(page)===true){hasChild="true";divChildIndicator='<div class="wcm-menu-child-indicator"></div>'}var sameLevelClass=this.isSameLevels(page)===true?"wcm-menu-brother":"";var ellipsisClass=page.title.indexOf(" ")===-1?" ellipsis ":"";var href=this.getHrefByPage(page);var style="background-image: url("+this.getIconByPage(page)+");";var menuItem=Mustache.render(this.templates.tpl_menu_item,{page:page.page,classes:sameLevelClass,ellipsisClass:ellipsisClass,hasChild:hasChild,pageId:page.pageId,title:page.title,href:href,style:style,divChildIndicator:divChildIndicator,submenu:submenu.innerHTML});this.jMenuList.append(menuItem)}this.size=this.menuPages.content.length-this.removedPages;this.jMenuList.append(Mustache.render(this.templates.tpl_menu_more,{}));this.addLinkBack();this.refreshItemActive();this.bindMouseEvents();this.refreshMenu(true);$(".wcm-menu-more-container").removeClass("wcm-menu-overflow-hidden")}this.bindEvents()},setColumnAmount:function(ul,size,columnLimitSize){if(size&&size>columnLimitSize&&ul){var columnAmount=Math.ceil(size/columnLimitSize);this.addStyleAttribute(ul,"columns",columnAmount);this.addStyleAttribute(ul,"-webkit-columns",columnAmount);this.addStyleAttribute(ul,"-moz-columns",columnAmount)}},addStyleAttribute:function(element,attrName,attrValue){this.addAttribute(element,"style",attrName+": "+attrValue)},addAttribute:function(element,attrName,attrValue){var previousValue=$(element).attr(attrName);if(previousValue){$(element).attr(attrName,previousValue+" "+attrValue+";")}else{$(element).attr(attrName,attrValue+";")}},bindEvents:function(){var self=this;function refreshMenu(){self.refreshMenu(false)}$(window).off("resize",refreshMenu);$(window).bind("resize",refreshMenu);window.addEventListener("popstate",function(event){self.changeHistoryURI(event.state)});WCMAPI.addListener(this,"DELETED_PAGE_EVENT",function(evname,menus){for(var i=0;i<menus.length;i++){$("#wcm-menu-list li[id="+menus[i]+"]").remove();$("div [class=submenucont] ul li").find("a[pagecode="+menus[i]+"]").remove()}})},changeHistoryURI:function(data){if(data){window.location.href=window.location.href}},addToMore:function(idItem,start,position){var jCloneItem=$("#"+idItem).clone();jCloneItem.removeClass("wcm-menu-item");jCloneItem.addClass("wcm-menu-more-item");jCloneItem.show();jCloneItem.off("click");jCloneItem.on("click",function(){$("#"+$(this).attr("id")).find("a").trigger("click")});if(position>5){position=0}if(position==0){var ulCode="ulItemId"+idItem;var ulItem='<li id="moreMenuListItem"><ul id="'+ulCode+'" style="display:block"></ul></li>';$(this.MENU_MORE_CONTENT_CLASS).append(ulItem)}$(this.MENU_MORE_CONTENT_CLASS+" #moreMenuListItem:last ul").append(jCloneItem);return position+1},updateIndicator:function(){var jItemActive=$(".wcm-menu-item-active");if(!jItemActive.length){return}var parentId=jItemActive.attr("parentId");if(parentId){var menuParent=$("a[pageId="+parentId+"]");if(menuParent.length>0){menuParent.parent().trigger("click")}}else{jItemActive.parent().trigger("click")}},refreshMenu:function(start){var moreCounter=0;var jNavigation=$(".wcm-navigation");var offsetTopParent=jNavigation.offset().top;this.hasMore=false;this.jMenuMore.hide();$(this.MENU_MORE_CONTENT_CLASS).empty();var self=this;this.jMenuItem.each(function(index){var jItem=$(this);if(!jItem.hasClass("wcm-menu-home")){if(jItem.css("display")=="none"){jItem.show()}$(jItem).find(".wcm-menu-child-indicator").attr("style","display:block");var positionBottomBorderItem=jItem.offset().top-offsetTopParent+jItem.innerHeight()*2;var heightWindow=$(window).height()-parseInt(jNavigation.css("top"));positionBottomBorderItem+=self.jMenuMore.innerHeight();if(positionBottomBorderItem>heightWindow&&(index!=self.size-1||self.hasMore)){if(jItem.find("a").hasClass("wcm-menu-item-active")){self.hasMore=true;self.jMenuMore.show();var lastShownIdx=index-1;var lastShownItem=$(self.jMenuItem[lastShownIdx]);while(lastShownItem.css("display")=="none"){lastShownIdx--;lastShownItem=$(self.jMenuItem[lastShownIdx])}lastShownItem.hide();moreCounter=self.addToMore(lastShownItem.attr("id"),start,moreCounter)}else{self.hasMore=true;self.jMenuMore.show();jItem.hide();moreCounter=self.addToMore(jItem.attr("id"),start,moreCounter)}}}});$(".wcm-menu-more").find(".wcm-menu-child-indicator").each(function(index){$(this).attr("style","display:none")});this.updateIndicator();this.jMenuMoreContainer.hide();refreshMoreMenu();refreshLuminosityMenu();this.resizeTitleMenuItem()},bindMouseEvents:function(){this.jMenuMoreContainer=$(".wcm-menu-more-container");this.jMenuMore=$(".wcm-menu-more");var jMenuMoreLinks=this.jMenuMore.find("a");var self=this;jMenuMoreLinks.off("mouseenter");jMenuMoreLinks.on("mouseenter",function(){self.jMenuMoreContainer.stop(true,true).fadeIn()});this.jMenuMore.off("mouseleave");this.jMenuMore.on("mouseleave",function(){self.jMenuMoreContainer.stop(true,true).fadeOut()});this.jMenuItem=this.jMenuList.find(".wcm-menu-item");this.jMenuItem.off("mouseover");this.jMenuItem.on("mouseover",function(){$(this).find(".submenu").show()});this.jMenuItem.off("mouseout");this.jMenuItem.on("mouseout",function(){$(this).find(".submenu").hide()});this.jMenuList.slideArrow($("li"),$(".wcm-menu-indicator-top"))},refreshItemActive:function(){if(this.controlPanelPage){this.jMenuList.find("li a[pagecode=cpaneladmin]").each(function(){$(this).addClass("wcm-menu-item-active");$(this).parent().addClass("wcm-menu-active");$(this).find("div[pagecode=cpaneladmin]").show()})}else{this.jMenuList.find("li a[pageId="+WCMAPI.getPageId()+"]").each(function(){$(this).addClass("wcm-menu-item-active");$(this).parent().addClass("wcm-menu-active");$(this).find("div[pageId="+WCMAPI.getPageId()+"]").show()})}},addLinkBack:function(){var href=null;if(this.previousPage.pageKey.code==this.COMMUNITY){href=WCMAPI.getProtectedContextPath()+"/"+WCMAPI.getTenantCode()+"/communities"}else{if(this.menuPages.content.length==0||this.previousPage.menuGroup||this.currentPage.parent==0){href=WCMAPI.getProtectedContextPath()+"/"+WCMAPI.getTenantCode()+"/home"}else{if(this.currentPage.parent!=0){href=WCMAPI.getServerURL()+WCMAPI.getProtectedContextPath()+"/"+WCMAPI.getTenantCode()+"/"+this.previousPage.pageKey.code}}}var linkBack="<li><a class='wcm-luminosity-menu-color' href='"+href+"' style='padding-top:10px'>Voltar</a></li>";if(this.currentPage.title!="Home"){this.jMenuList.append(linkBack)}},hasChildren:function(page){return page.children&&page.children.length>0},getHrefByPage:function(page){if(page.menuGroup&&this.hasChildren(page)===true){return this.getPrefixUrl()+page.children[0].uri}return this.getPrefixUrl()+page.uri},isSameLevels:function(page){return this.currentPage.disableChildLevel&&page.parentId&&page.parentId!==this.currentPage.pageKey.id},setSessionAttribute:function(value){WCMAPI.setSessionAttribute("app_mainmenu_selected_context",value)},findPageSync:function(pageId,editMode){var page=this.restSync(WCMSpaceAPI.PageService.FINDPAGE,[pageId,editMode]);return page?page.content:null},findPage:function(pageId,editMode,callback){this.rest(WCMSpaceAPI.PageService.FINDPAGE,[pageId,editMode],callback)},findPreviousPage:function(callback){var self=this;self.rest(WCMSpaceAPI.PageService.FINDPREVIOUSPAGE,[self.getCurrentPageId()],callback)},getCurrentPageId:function(){if(this.currentPage){return this.currentPage.pageKey.id}else{if(WCMAPI.getParentPageCode()=="subject"){return this.findPageSync(WCMAPI.getPageId(),WCMAPI.isEditMode).parent}else{return WCMAPI.getPageId()}}},loadCurrentPage:function(){var self=this;self.findPage(self.getCurrentPageId(),WCMAPI.isEditMode,function(page){self.currentPage=page?page.content:null;self.loadPreviousPage()})},resizeTitleMenuItem:function(){var target=$("#wcm-menu-list li a");var limit=40;var textLimited="";var textLenght="";target.each(function(){textLenght=$(this).text().length;if(textLenght>limit){textLimited=$(this).text();$(this).text(textLimited.substr(0,limit)+"...")}})},loadPreviousPage:function(){var self=this;self.findPreviousPage(function(page){self.previousPage=page?page.content:null;if(self.previousPage==-1){self.previousPage=this.currentPage}self.controlPanelPage=null;if(self.previousPage.hidden){self.findPage(self.previousPage.parent,WCMAPI.isEditMode,function(panelPage){panelPage=panelPage?panelPage.content:null;if(panelPage&&panelPage.pageKey.code==self.CPANEL_ADMIN){self.currentPage=self.previousPage=self.controlPanelPage=panelPage;self.setSessionAttribute(self.CPANEL_ADMIN)}self.loadMenus()})}else{self.loadMenus()}})}});