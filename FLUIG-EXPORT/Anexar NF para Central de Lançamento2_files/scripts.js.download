            retornoStatus = datasetFilhosProcesso.values[0].status;
    	    console.log("TesteValidaçãoStatus"+retornoStatus);
           } catch(erro) {

           }

    } catch(erro) {

    }
    
    if (retornoNF != "" && retornoNF != null  ){
        if (retornoStatus != '1'){
        //$("#notaDuplicada").val(retornoNF);
        $("#notaDuplicadaP").val('S');
        
        FLUIGC.message.alert({
            message: 'O Número de Nota Fiscal informado já foi incluído anteriomente para este fornecedor, verifique antes de realizar o lançamento!',
            title: 'Nota Fiscal Duplicada para o Fornecedor Selecionado',
            label: 'OK'
        });
        }else{
        	$("#notaDuplicadaP").val('N');
        }
        
    }else{
        $("#notaDuplicadaP").val('N');
    }
    
	}

	}


