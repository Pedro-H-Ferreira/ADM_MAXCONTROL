function quantTotal() {
	  var total = 0;
	  $("input[id^='numProduto___']").each(function () {
	    if ($(this).val()) {
	      total = parseFloat($(this).val());
	    }
	  });
	  // Setando o valor total geral de despesas
	  //$("#totalSol").val(mascaraBR('moeda', total));
	  $("#qtDespesas").val(total);
	  //calcularTotalGeralViagem();
	}

function quantTotalParcelas() {
	  var total = 0;
	  $("input[id^='parcelas___']").each(function () {
	    if ($(this).val()) {
	      total = parseFloat($(this).val());
	    }
	  });
	  // Setando o valor total geral de despesas
	  //$("#totalSol").val(mascaraBR('moeda', total));
	  $("#qtDespesas").val(total);
	  //calcularTotalGeralViagem();
	}

//Função auxiliar para converter "1.000,00" em 1000.00 (número real)
function converterParaNumero(valor) {
    if (!valor) return 0;
    // Remove pontos de milhar e troca vírgula por ponto
    var numeroLimpo = valor.replace(/\./g, '').replace(',', '.');
    return parseFloat(numeroLimpo) || 0;
}

