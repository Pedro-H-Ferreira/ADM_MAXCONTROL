	      var books4 = catalog2.getElementsByTagName("ICMSTot");
	      var books5 = catalog.getElementsByTagName("prod");
	      var books6 = catalog.getElementsByTagName("dup");
	      [].forEach.call(books, function (node, indice) {
	        var ide = new Book(node); 

	        console.log("TesteXMLModelo"+ide.mod);
	        console.log("TesteXMLNota"+ide.nNF);
	        console.log("TesteXMLDtEmissão"+ide.dhEmi);
	        console.log("TesteXMLSerie"+ide.serie);
	        
