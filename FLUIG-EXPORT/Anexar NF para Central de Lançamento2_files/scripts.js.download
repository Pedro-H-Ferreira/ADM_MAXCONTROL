function bloqueiaDataLanc(){
	

	  var id = 0;
	  $("input[id^='numProduto___']").each(function () {
	    if ($(this).val()) {
	      id = parseFloat($(this).val());
	    }
	  });

	console.log(id);


	// Esta linha cria a variável calendário que receberá a chamada FLUIGC.calendar():
	var calendario = FLUIGC.calendar("#vencPagNota___" + id);
	console.log("NumeroData >> " + calendario);
	console.log(calendario);
	// Cria a variável com a data atual:
	var dataAtual = new Date();
	
	// Adiciona 3 dias na data atual, você pode alterar este valor conforme necessário:
	var dias = 15;
	// Incrementa a quantidade de dias na data atual:
	dataAtual.setDate(dataAtual.getDate() + dias);
	
	console.log("Nova data" + dataAtual);
	

	// Define que o valor mínimo a ser selecionado no calendário:
	calendario.setMinDate(dataAtual);
	
	console.log("Data Atualizada" + calendario);
}

function bloqueiaDataNF(){


	// Esta linha cria a variável calendário que receberá a chamada FLUIGC.calendar():
	var calendario = FLUIGC.calendar("#vencPagNota");
	console.log("NumeroData >> " + calendario);
	console.log(calendario);
	// Cria a variável com a data atual:
	var dataAtual = new Date();
	
	// Adiciona 3 dias na data atual, você pode alterar este valor conforme necessário:
	var dias = 0;
	// Incrementa a quantidade de dias na data atual:
	dataAtual.setDate(dataAtual.getDate() + dias);
	
	console.log("Nova data" + dataAtual);
	

	// Define que o valor mínimo a ser selecionado no calendário:
	calendario.setMinDate(dataAtual);
	
	console.log("Data Atualizada" + calendario);
}
