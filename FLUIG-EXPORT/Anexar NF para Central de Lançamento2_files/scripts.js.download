function ajustadata(){
    //var data = new Date();
    
    var data =$("#vencPagNota").val();
	console.log("Datas1: " + data);
    var datset = document.getElementById("datemed").value;
    datset = datset.replace("/","");
    var hoje3 = ("0" + (data.getDate()-3)).substr(-2) + "" + ("0" + (data.getMonth() + 1)).substr(-2) + "" + data.getFullYear();

    var condicao = hoje3 - (datset.replace("/",""));

    var mini = ("0" + (data.getDate()-3)).substr(-2) + "/" + ("0" + (data.getMonth() + 1)).substr(-2) + "/" + data.getFullYear();
    console.log("Datas2: " + mini);
    
    if (condicao > 0){
        FLUIGC.message.alert({
            message: 'A data da ocorrência deve ser imputada somente com 3 dias atrás!',
            title: 'Erro na Data da Ocorrência',
            label: 'OK'
        });
       
        document.getElementById("datemed").value = mini;
    }
	//$("#datemed").val(mini);
}

function ajustaPrazoCentral(){
	
	// Recuperando a data informada no campo do formulário
    //var prazoFormulario = hAPI.getCardValue('dataEmissaoNF');
	var prazoFormulario = $("#vencPagNota").val();
	console.log("Datas0: " + prazoFormulario);
    /* Extrai os dados da data do formulário para um array, para posteriormente transformar em data do Javascript */
    var arrayPrazoConclusao = prazoFormulario.split("/");
    var dia = arrayPrazoConclusao[0]; // Posição 0 do array é o dia
    var mes = arrayPrazoConclusao[1] - 1; // Posição 1 do array é o mês (Subtraímos 1 porque na data do Javascript o mês vai de 0 a 11)
    var ano = arrayPrazoConclusao[2]; // Posição 2 do array é o ano
    // Cria a data no Javascript
    var dataDoPrazo = new Date();
    dataDoPrazo.setDate(dia);
    dataDoPrazo.setMonth(mes);
    dataDoPrazo.setFullYear(ano);
	var dia = dataDoPrazo;
	//var dia = new Date();
	console.log("Datas1: " + dia);
	//dia.setDate(dia.getDate() - 15);
	
	dia.setDate(dia.getDate() - 7);
	console.log("Datas2: " + dia);
	

	FLUIGC.calendar("#vencPagNota", { 
	  language: 'pt-br',
	  minDate: dia,
	  maxDate: new Date(),
	  pickDate: true,
	  pickTime: false 
	});

	var today = dia;
	console.log("Datas3: " + today);
	var year = today.getFullYear();
	var month = (today.getMonth() + 1) < 10 ? '0' + (today.getMonth() + 1)	: (today.getMonth() + 1);
	var day = today.getDate() < 10 ? '0' + today.getDate() : today.getDate();		
	var hour = today.getHours() < 10 ? '0' + today.getHours() : today.getHours();
	var minute = today.getMinutes() < 10 ? '0' + today.getMinutes() : today.getMinutes();
	var second = today.getSeconds() < 10 ? '0' + today.getSeconds() : today.getSeconds();
	var currentHour = hour + ":" + minute + ":" + second;
	var currentDate = day + '/' + month + '/' + year;
	console.log("Datas4: " + currentDate);
	

	$("#prazoAtenderCentral").val(currentDate);

}

