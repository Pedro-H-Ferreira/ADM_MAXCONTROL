//Verifica NF
function verificaNF() {
	
	//Ajusta valorTotal
    var idvalorNF = parseFloat($("#valorNF").val().replace(/\./g,"").replace(",","."));
    $("#valorNFT").val(idvalorNF);
    var idNotaFiscal = +$("#nNotaFiscal").val();
    $("#nNotaFiscal").val(idNotaFiscal);
    var idCNPJ =$("#codCNPJ").val();
	console.log("TesteVerificaNF"+idNotaFiscal);
	console.log("TesteVerificaNFCNPJ"+idCNPJ);
	const idDatasetFormulario = 'formAtendimentoCentralLancamento';
    //Cria as constraints para buscar os campos
    var constraintsFilhos = new Array();
    constraintsFilhos.push( DatasetFactory.createConstraint( "nNotaFiscal", idNotaFiscal,idNotaFiscal, ConstraintType.MUST ) );
    constraintsFilhos.push( DatasetFactory.createConstraint( "codCNPJ", idCNPJ ,idCNPJ, ConstraintType.MUST ) );
    //constraintsFilhos.push( DatasetFactory.createConstraint( "nNotaFiscal", "00" ,"00", ConstraintType.MUST_NOT ) );

            //Teste de retorno da informação coletada
            //Busca o dataset
    try {
        var datasetFilhos = DatasetFactory.getDataset( idDatasetFormulario, null, constraintsFilhos, null);

        var retornoNF;
        var retornoProcesso;
        var retornoDocId;
        var size = (datasetFilhos.values['length'])-(1);
    	console.log("TesteValidaçãoQuant"+size);

        retornoNF = datasetFilhos.values[size].nNotaFiscal;
        retornoProcesso = datasetFilhos.values[size].numeroSolicitacao;
        retornoDocId = datasetFilhos.values[size].documentid;

    	console.log("TesteValidaçãoNotaLançada"+retornoNF);
    	console.log("TesteValidaçãoProcesso"+retornoProcesso);
    	console.log("TesteValidaçãoDocId"+retornoDocId);

        //Teste de status do processo
        var constraintsFilhosProcesso = new Array();
        constraintsFilhosProcesso.push( DatasetFactory.createConstraint( "cardDocumentId", retornoDocId,retornoDocId, ConstraintType.MUST ) );

    	try{
            var retornoStatus;
            var datasetFilhosProcesso = DatasetFactory.getDataset( "workflowProcess", null, constraintsFilhosProcesso, null);
            retornoStatus = datasetFilhosProcesso.values[0].status;
    	    console.log("TesteValidaçãoStatus"+retornoStatus);
           } catch(erro) {

           }

    } catch(erro) {

    }
    
    if (retornoNF != "" && retornoNF != null  ){
        if (retornoStatus != '1'){
        //$("#notaDuplicada").val(retornoNF);
        $("#notaDuplicada").val('S');
        
        FLUIGC.message.alert({
            message: 'O Número de Nota Fiscal informado já foi incluído anteriomente para este fornecedor, verifique antes de realizar o lançamento!',
            title: 'Nota Fiscal Duplicada para o Fornecedor Selecionado',
            label: 'OK'
        });
        }else{
        	$("#notaDuplicada").val('N');
        }
        
    }else{
        $("#notaDuplicada").val('N');
    }

	}

