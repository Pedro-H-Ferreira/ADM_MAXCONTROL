	      total += parseFloat($(this).val().replaceAll(".", "").replace(",", "."));
	    }
	  });
	  // Setando o valor total geral de despesas
	  //$("#totalSol").val(mascaraBR('moeda', total));
	  $("#valorNotaFiscal").val(mascaraBR('moeda', total));
	  //calcularTotalGeralViagem();
	}

