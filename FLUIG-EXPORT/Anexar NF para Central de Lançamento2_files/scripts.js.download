	  		  		          }


	        
	    }
	  });
	  httpRequest.send();

	});
  
	          



	
	
	
}

//Verifca a Alçada de Aprovação
function alcadaAprovacao(){

    var valorNFAlcada = parseFloat($("#valorNF").val().replace(/\./g,"").replace(",","."));
    var valor1 = 1500.00;
    var valor2 =10000.00;

    console.log("valorNF"+ valorNFAlcada);

    var selecaoOrcamento = $('input[name=radioExtraOrc]:checked').val();
    
    console.log("Extra orc"+ selecaoOrcamento);
    

    // -- ALÇADAS DE APROVAÇÃO - 09/04/2026 
    
    //Alçada 1 - Regionais
    if(valorNFAlcada <= valor1){
        setaValor("tipoAlcada","1")       	
       }
    
     //Alçada 2 - Diretor de operações
     if(valorNFAlcada > valor1 && valorNFAlcada <= valor2){
        	setaValor("tipoAlcada","2")
        }
      
     //Alçada 3 - Diretor Financeiro / Acionistas
     if(valorNFAlcada > valor2){
        	setaValor("tipoAlcada","3")
        }
        	
	
}


//Retorna os dados de Gerente e Gerente regional
function retornaGerente() {

  var idFilial =$("#coFilial").val();
  console.log('(Retorna Gerente) Esse é o código da filial:'+idFilial);
  const idDatasetFormulario = 'dsLeituraCadastroGerenteRegionalDD';
  //Cria as constraints para buscar os campos
  var constraintsFilhos = new Array();
  constraintsFilhos.push( DatasetFactory.createConstraint( "codFilial", idFilial,idFilial, ConstraintType.MUST ) );

          //Teste de retorno da informação coletada
          //Busca o dataset
          try {
              var datasetFilhos = DatasetFactory.getDataset( idDatasetFormulario, null, constraintsFilhos, null);

              var retornoGerente;
              var retornoNomeGerente;
              var retornoGerenteRegional;
              var retornoNomeGerenteRegional;
              retornoGerente = datasetFilhos.values[0].codGerente;
              retornoNomeGerente = datasetFilhos.values[0].descricaoFilial;
              retornoNomeGerenteRegional = datasetFilhos.values[0].nomeGerenteRegional;
              retornoGerenteRegional = datasetFilhos.values[0].codGerenteRegional;

          	console.log("TesteValidaçãoGerente"+retornoGerente);
          	console.log("TesteValidaçãoGerenteGeral"+retornoGerenteRegional);
          	console.log("TesteValidaçãonomeGerenteGeral"+retornoNomeGerenteRegional);
          	setaValor("matGerenteLojaArea",retornoGerente);
          	setaValor("nomeGerenteLojaArea",retornoNomeGerente);
          	setaValor("matGerenteRegionalArea",retornoGerenteRegional);
          	setaValor("nomeGerRegional",retornoNomeGerenteRegional);
          	

          } catch(erro) {
        	  	console.log('(RetornaGerente) Erro: '+erro);
            	setaValor("matGerenteLojaArea",retornoGerente);
            	setaValor("nomeGerenteLojaArea",retornoNomeGerente);
              	setaValor("matGerenteRegionalArea",retornoGerenteRegional);
              	setaValor("nomeGerRegional",retornoNomeGerenteRegional);

          }

          


	}


//Retorna os das Contas Financeiras que possuem regras de Exceção
function retornaContaExcecao() {

  //var idConta =$("#contaCentroCusto").val();
  const idDatasetFormulario = 'dsConsultaCadastroExcecaoContasPrazosDD';
  //Cria as constraints para buscar os campos
  var constraintsFilhos = new Array();
  constraintsFilhos.push( DatasetFactory.createConstraint( "codConta", idConta,idConta, ConstraintType.MUST ) );

          //Teste de retorno da informação coletada
          //Busca o dataset
          try {
              var datasetFilhos = DatasetFactory.getDataset( idDatasetFormulario, null, constraintsFilhos, null);

              var retornoConta;
              var retornoDescricao;
              var retornoPrazoMinimo;
              var retornoPrazoMaximo;
              retornoConta = datasetFilhos.values[0].CodConta;
              retornoDescricao = datasetFilhos.values[0].Descricao;
              retornoPrazoMinimo = datasetFilhos.values[0].PrazoMinimo;
              retornoPrazoMaximo = datasetFilhos.values[0].PrazoMaximo;

          	console.log("TesteValidaçãoConta"+retornoConta);
          	console.log("TesteValidaçãoContaDesc"+retornoDescricao);
          	console.log("TesteValidaçãoMinimo"+retornoPrazoMinimo);
          	console.log("TesteValidaçãoMaximo"+retornoPrazoMaximo);
          	//setaValor("matGerenteLojaArea",retornoConta)
