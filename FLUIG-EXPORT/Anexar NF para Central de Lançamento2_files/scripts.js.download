	    	// Recuperando a data emissão informada no campo do XML
	    	var prazoFormularioX = resutadodataemissão;
	    	console.log("Datas0: " + prazoFormularioX);
	        /* Extrai os dados da data do formulário para um array, para posteriormente transformar em data do Javascript */
	        var arrayPrazoConclusaoX = prazoFormularioX.split("-");
	        var anoX = arrayPrazoConclusaoX[0]; // Posição 0 do array é o dia
	        var mesX = arrayPrazoConclusaoX[1] - 1; // Posição 1 do array é o mês (Subtraímos 1 porque na data do Javascript o mês vai de 0 a 11)
	        var diaX = arrayPrazoConclusaoX[2]; // Posição 2 do array é o ano
