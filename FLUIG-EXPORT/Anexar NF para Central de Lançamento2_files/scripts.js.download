

function lerDadosXML(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    
    reader.onload = function(e) {
        const xmlContent = e.target.result;
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(xmlContent, "text/xml");

        // Função auxiliar para buscar texto da tag
        const getTagText = (doc, tag) => {
            const element = doc.getElementsByTagName(tag)[0];
            return element ? element.textContent : "";
        };

        try {
            // 1. Extração - Dados básicos
            const nNF = getTagText(xmlDoc, "nNF");
            const serie = getTagText(xmlDoc, "serie");
            const mod = getTagText(xmlDoc, "mod");
            const cfop = getTagText(xmlDoc, "CFOP"); // Pega o CFOP do primeiro item
            
            // 2. Extração - Data de Emissão (NFe 4.00 usa dhEmi, versões antigas dEmi)
            let dEmi = getTagText(xmlDoc, "dhEmi") || getTagText(xmlDoc, "dEmi");
            if (dEmi) {
                dEmi = dEmi.split("T")[0]; // Separa a data da hora
                const parts = dEmi.split("-");
                if (parts.length === 3) {
                    dEmi = `${parts[2]}/${parts[1]}/${parts[0]}`; // Formata para DD/MM/YYYY
                }
            }

            // 3. Extração - Data de Vencimento
            let dVenc = getTagText(xmlDoc, "dVenc");
            if (dVenc) {
                const parts = dVenc.split("-");
                if (parts.length === 3) {
                    dVenc = `${parts[2]}/${parts[1]}/${parts[0]}`; // Formata para DD/MM/YYYY
                }
            }

            // 4. Extração - Valor Total da Nota
            let vNF = "";
            const vNFElement = xmlDoc.querySelector("ICMSTot > vNF") || xmlDoc.getElementsByTagName("vNF")[0];
            if (vNFElement) {
                // Formata de 1141.75 para 1.141,75
                vNF = parseFloat(vNFElement.textContent).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            // 5. Extração - CNPJ do Emitente
            const emitNode = xmlDoc.getElementsByTagName("emit")[0];
            const cnpjEmit = emitNode ? getTagText(emitNode, "CNPJ") : "";

            // 6. Extração - Chave de Acesso
            let chave = getTagText(xmlDoc, "chNFe");
            if (!chave) { // Fallback caso a tag chNFe não exista diretamente
                const infNFe = xmlDoc.getElementsByTagName("infNFe")[0];
                chave = infNFe ? infNFe.getAttribute("Id").replace("NFe", "") : "";
            }

            // ==========================================
            // PREENCHIMENTO DOS CAMPOS NA TELA
            // ==========================================
            $("#nNotaFiscal").val(nNF).trigger('blur');
            $("#serie").val(serie);
            $("#modelo").val(mod);
            $("#CFOP").val(cfop);
            $("#dataEmissaoNF").val(dEmi);
            
            // Só preenche o vencimento se ele existir no XML
            if(dVenc) {
                $("#vencPagNota").val(dVenc).trigger('change');
            }
            
            $("#valorNF").val(vNF).trigger('input'); // Aciona input para formatar a máscara do Fluig
            $("#codCNPJ").val(cnpjEmit);
            $("#chaveXML").val(chave);

            // Reseta o input file para permitir selecionar o mesmo arquivo novamente se precisar
            $("#fileUpload").val(''); 

            // Aviso de Sucesso
            if(typeof FLUIGC !== 'undefined') {
                FLUIGC.toast({
                    title: 'Sucesso! ',
                    message: 'Dados principais da nota preenchidos. Por favor, preencha o Fornecedor, Centro de Custo e demais informações.',
                    type: 'success'
                });
            } else {
                alert("Dados preenchidos! Complete o restante do formulário.");
            }

        } catch (error) {
            console.error("Erro no XML:", error);
            if(typeof FLUIGC !== 'undefined') {
                FLUIGC.toast({
                    title: 'Erro! ',
                    message: 'Arquivo XML inválido ou fora do padrão.',
                    type: 'danger'
                });
            }
        }
    };

    reader.readAsText(file);
}





