function SocialDATAAPI(){}
function SocialDATAAPI_MentionService(){}
SocialDATAAPI_MentionService.prototype.basePath = function(){
return "/social/api/rest/mention";}
SocialDATAAPI.prototype.ajaxCall = function(__httpMethod__, __callData, __cmdurl__, __datatype__, __contentType__, __postdata__){
var 	__ret__=null;
	jQuery.ajax( {
    	type : __httpMethod__ ,
    	async : __callData.async,
    	url : __cmdurl__ ,
    	dataType : __datatype__,
    	contentType: __contentType__ +"; charset=utf-8",
    	data: __postdata__,
    	success : function(response) {
if (      	__callData.async == false){
      	__ret__=response;
}else{
      	__callData.success.call(__callData.oObj, response, __callData);
}
    	},
    	error : function(XMLHttpRequest, textStatus, errorThrown) {
      	errorThrown=eval('('+XMLHttpRequest.responseText+')');
      	if (__callData.errorCallback) {
          	__callData.errorCallback.call(__callData.oObj, XMLHttpRequest, textStatus, errorThrown, __callData);
      	}else{
          	throw errorThrown;
    	}}
	});
if (	__callData.async == false){
    	return __ret__;
}
	}
SocialDATAAPI_MentionService.prototype.REPLACEMENTIONS__PATH = function(){
return "/social/api/rest/mention"+"/";}
SocialDATAAPI_MentionService.prototype.REPLACEMENTIONS = function(__callData,objectId,objectClass,hasMentions,objectText,replacePattern){
var __cmdurl__="/social/api/rest/mention"+"/";
var __ret__=null;
WCMAPI.extendSession();
__cmdurl__+="?space=" + WCMAPI.getSpaceAlias() + "";
if (objectId){
__cmdurl__+="&objectId=";
__cmdurl__+=encodeURIComponent(objectId);
}
if (objectClass){
__cmdurl__+="&objectClass=";
__cmdurl__+=encodeURIComponent(objectClass);
}
if (hasMentions){
__cmdurl__+="&hasMentions=";
__cmdurl__+=encodeURIComponent(hasMentions);
}
if (objectText){
__cmdurl__+="&objectText=";
__cmdurl__+=encodeURIComponent(objectText);
}
if (replacePattern){
__cmdurl__+="&replacePattern=";
__cmdurl__+=encodeURIComponent(replacePattern);
}
__ret__=SocialAPI.ajaxCall("GET", __callData, __cmdurl__, "text", "application/x-www-form-urlencoded", undefined);
    return __ret__;
}
SocialDATAAPI.prototype.MentionService=new SocialDATAAPI_MentionService;
