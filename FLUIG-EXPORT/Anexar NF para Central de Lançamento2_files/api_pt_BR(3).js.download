function UsePolicyDATAAPI(){}
function UsePolicyDATAAPI_UsePolicyService(){}
UsePolicyDATAAPI_UsePolicyService.prototype.basePath = function(){
return "/usepolicyapi/api/rest/usepolicy";}
UsePolicyDATAAPI.prototype.ajaxCall = function(__httpMethod__, __callData, __cmdurl__, __datatype__, __contentType__, __postdata__){
var 	__ret__=null;
	jQuery.ajax( {
    	type : __httpMethod__ ,
    	async : __callData.async,
    	url : __cmdurl__ ,
    	dataType : __datatype__,
    	contentType: __contentType__ +"; charset=utf-8",
    	data: __postdata__,
    	success : function(response) {
if (      	__callData.async == false){
      	__ret__=response;
}else{
      	__callData.success.call(__callData.oObj, response, __callData);
}
    	},
    	error : function(XMLHttpRequest, textStatus, errorThrown) {
      	errorThrown=eval('('+XMLHttpRequest.responseText+')');
      	if (__callData.errorCallback) {
          	__callData.errorCallback.call(__callData.oObj, XMLHttpRequest, textStatus, errorThrown, __callData);
      	}else{
          	throw errorThrown;
    	}}
	});
if (	__callData.async == false){
    	return __ret__;
}
	}
UsePolicyDATAAPI_UsePolicyService.prototype.ADDNEWDOCUMENTTOUSEPOLICY__PATH = function(){
return "/usepolicyapi/api/rest/usepolicy"+"/document";}
UsePolicyDATAAPI_UsePolicyService.prototype.ADDNEWDOCUMENTTOUSEPOLICY = function(__callData,obj_PolicyDocument){
var __cmdurl__="/usepolicyapi/api/rest/usepolicy"+"/document";
var __ret__=null;
WCMAPI.extendSession();
__cmdurl__+="?space=" + WCMAPI.getSpaceAlias() + "";
__ret__=UsePolicyAPI.ajaxCall("POST", __callData, __cmdurl__, "application/json", "application/json", JSON.stringify(obj_PolicyDocument));
    return __ret__;
}
