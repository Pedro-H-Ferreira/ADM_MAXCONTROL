//Popular tabela de rateio

function populaTabelaRateio() {

	
	var x = document.getElementById("tableItens").rows.length;
	console.log("tamanho tabela = " + x);

	var table = document.getElementById("bodyTabela");
	for (var c = 1; c < x; c++) {
		var tr = document.createElement('tr');
		tr.setAttribute("id", "idTr" + c);

		// Cria as TD da tabela
		//var tdNFRateio = document.createElement('td');
		var tdcentroCustoRateio = document.createElement('td');
		var tdvalorRateio = document.createElement('td');



		// Define o ID para a TD
		//tdNFRateio.setAttribute("id", "NFRateio" + c);
		tdcentroCustoRateio.setAttribute("id", "centroCustoRateio" + c);
		tdvalorRateio.setAttribute("id", "valorRateio" + c);


		

		// Add as Linhas
		//tr.appendChild(tdNFRateio);
		tr.appendChild(tdcentroCustoRateio);
		tr.appendChild(tdvalorRateio);



		table.appendChild(tr);
	}

	//document.getElementById("bodyTabela").appendChild(table);

	for (var i = 1; i < x; i++) {
		var num = parseInt(i);
		// alert(num)
		// Captura os valores

		//var vNFRateio = document.getElementById("NFRateio___" + i).value;
		var vcentroCustoRateio = document.getElementById("centroCustoRateio___" + i).value;
		var vvalorRateio = document.getElementById("valorRateio___" + i).value;


		

		// Grava na TD Criada anteriormente
		//document.getElementById("NFRateio" + i).innerHTML = vNFRateio;
		document.getElementById("centroCustoRateio" + i).innerHTML = vcentroCustoRateio;
		document.getElementById("valorRateio" + i).innerHTML = vvalorRateio;


		

	}

	
	
	
	
}


