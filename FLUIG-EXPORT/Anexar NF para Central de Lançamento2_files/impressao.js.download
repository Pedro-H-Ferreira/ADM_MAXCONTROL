/*******************************************************************************
 * Preenche a tabela com os dados preenchidos
 ******************************************************************************/
function imprimirTabela() {
	  document.getElementById("divPrincipal").setAttribute("style", "display: none"); 
	  
	  document.getElementById("divImpressao").setAttribute("style", "display: "); 
	  
	  document.getElementById("imprimirForm").setAttribute("style", "display: none"); 
	  
	  
	}
function voltarimprimirTabela() {
	  document.getElementById("divPrincipal").setAttribute("style", "display: "); 
	  
	  document.getElementById("divImpressao").setAttribute("style", "display: none"); 
	  
	  document.getElementById("imprimirForm").setAttribute("style", "display: "); 
	}


