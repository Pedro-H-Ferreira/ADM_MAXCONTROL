function showCamposDefinir(){
    // Verificando o seleção do rateio
    var definirCF = $('input[name=definirNF]:checked').val();
    if ( definirCF == "fornecedor" ) {
        $("#idfornecedorC").show();
        $("#idfuncionarioC").hide();
       
        
    } else {
        $("#idfornecedorC").hide();
        $("#idfuncionarioC").show(); 
    }

}

// Função para Mostrar campos relacionados a central
function showCamposCentral(){
    // Verificando o seleção do rateio
    var camposCentral = $('input[name=radioLancaInputNF]:checked').val();
    if ( camposCentral == "nao" ) {
        $("#painelCabecalho").show();
        $("#painelLancaWinthor").hide();
        
