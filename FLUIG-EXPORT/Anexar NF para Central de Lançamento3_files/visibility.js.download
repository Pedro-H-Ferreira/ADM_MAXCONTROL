// Variáveis para código das atividade
var inicio = 0;
var inicio1 = 4;
var analisePagamento = 262;
var realizarAjusteGestor = 93;
var AprovGestor = 60;
var AprovDiretor = 107;
var AprovGerenteRegional = 212;
var AprovPresidente = 196;
var realizarAjusteGerenteRegional = 225;
var realizarAjustePresidente = 206;
var realizarAjusteDiretor = 111;
var realizarAjusteControladoria = 181;
var realizarAnalisePagamento = 268;
var analisarLancarNF = 64;
var solicitarAjusteNF = 87;
var corrigirProblemaPublicacao = 102;
var extraOrcamentario = 142;
var extraOrcamentarioCentral = 150;
