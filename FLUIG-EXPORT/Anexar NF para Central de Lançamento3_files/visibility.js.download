var fim2 = 68;


// Função principal
$(document).ready(function (obj) {
	

    initAtv();
    view();

    if(mobaiu == 'S'){
        viewMobile();
    }
    

    //Atualiza numero da solicitação
    if(AprovGestor == numProcess){
        setaValor("numeroSolicitacao",WKNumProces)
    }
    
    
    // Regra do campo "Incluir Rateio NF?"
    $("#idradiorateioNF").click(function(){
        console.log("Bloqueio do painel de Rateio");
        showCamposRateio();
    });
    
    //Regra do campo valor Adiantamento
    $("#idradioAntecipacao").click(function(){
        console.log("Boqueio do campo valor da Antecipação");
        showCamposAntecipacao();
    });
    
    //Regra para o XML
    $("#idradioParcelasNF").click(function(){
        console.log("Boqueio do painel do XML");
        showCamposParcelas();
    });    
    //Regra para o XML upload
    $("#idFileUpload").click(function(){
        console.log("Boqueio do painel os campos Filial e Fornecedor");
        showCamposBloqueadosXML();
    }); 
    //Verificar o preenchimento de funcionario ou fornecedor  
    $("#idDefinirNF").click(function(){
        console.log("Boqueio do painel de Funcionario e Fornecedor");
        showCamposDefinir();
    });     
    
    $("#idRadioLancaInputNF").click(function(){
        console.log("Boqueio do painel de Solicitação de Ajuste");
        showCamposCentral();
    });
    
    $("#idRadioPagamentoRealizado").click(function(){
        console.log("Liberar o campo demanda para finaceiro");
        showDemandaFinanceiro();
    });
    
    $("#idDescricaoDemandaEnvio").click(function(){
        console.log("Liberar o campo Carregamento");
        showCamposCarregamento();
    });
    
    $("#idNF").click(function(){
        console.log("Liberar o campo Carregamento");
        showCamposCarregamento();
    });
  
    $("#topBtn").click(function(){
        console.log("Liberar o campo Carregamento");
        showCamposCarregamento();
    });
    
    
    
    //Função de visualizar a data
    var numProcess = WKNumProces;
    if(numProcess == inicio){
	$.each($("[data-date]"), function(i, o) {
        var id = $(o).attr("id");
		FLUIGC.calendar("#" + id);
	});

    } 

    
});

//Realiza ações funcionais
function initAtv() {

    var atividade = WKNumState;
    
    if ( atividade == inicio || atividade == inicio1 ) {
        initCargo();
        initFluigCalendar();
    }    
    
    
    
}

//Mostra, oculta, bloqueia e libera campos
function view() {
    var atividade = WKNumState;

    
    
    //Protege o campo sobre análise de pagamento em outras atividades
    if (atividade != analisePagamento){
    	protege("#accordionChecagens")
    	$("#obsAnalisePgto").attr('readonly', true);
    	
    	

    	
    }
    
    // Regra para atividade Análise de pagamento
    if (atividade == analisePagamento){
    	
    	// Permissão de alteração (Não permite)
    	$("#formaPagamento").prop('disabled', true); // Não está funcionando 
    	$("#obsAreaContabil").attr('readonly',true); // Corrigido
    	
    	// Permissão de alteração (Permite)
        $("[id^=centroCustoRateio___]").attr('readonly', false); // Funciona
        $("#fornecedorC").attr('readonly', false); // Funciona 
        $("#codigonaturezaC").attr('readonly', false); // Funciona
        $("[id^=valorRateio___]").attr('readonly', false);
        
        
        // Visualização (Mostra)
        $("#collapseCabecalhoEnvio").show(); // Funciona
        $("#accordionListaNFEnvio").show(); // Funciona
        $("#accordionRateioNF").show();//painel de Rateio
        $("#obsAreaContabil").show(); // Mostra observação de análise Contábil
        
        // Visualização (Esconde)
        $("#accordionAreaGestor").hide(); // Esconde Aprovação Gestor
        $("#accordionAreaGerRegional").hide(); // Esconde Aprovação Regional
        $("#accordionAreaDiretoria").hide(); // Esconde Aprovação Diretoria
        $("#accordionAreaPresidente").hide(); // Esconde aprovação Presidente
        $("#accordionAreaControladoria").hide(); // Esconde Ajuste Controladoria
        $("#accordionLancaInputNF").hide(); // Esconde Lançamento 
        $("#accordionCabecalho").hide(); // Esconde cabeçalho
        $("#accordionAtendimento").hide(); // Esconde aba de atendimento
        $("#accordionLancaWinthor").hide(); // Esconde aba de lançamento 
        $("#accordionFinanceiroDD").hide(); // Esconde aba do Financeiro
        $("#buttonRateio").hide(); // Esconde botão de adicionar rateio
      
        showCamposParcelas();
        showCamposRateio();
        showCamposAntecipacao();
        showCamposCentral();
        ajustarDataCentral();
        
        //Adicionar a função de Ativos em todas as tarefas
        showCamposAtivos();
     
		//filtroConta('liberado');
		filtroFuncionario("liberado");
	
		filtroFornecedor("liberado");
		salvaNatureza();
		

    }
    
    //bloqueios
 // VERSÃO CORRIGIDA E MAIS ROBUSTA
    if(atividade != inicio && atividade != inicio1 &&  atividade != realizarAjusteGestor && atividade != corrigirProblemaPublicacao && atividade != providenciarAjustes && atividade != providenciarAjustesAtraso && atividade !=  realizarAjusteFinanceiro && atividade !=  realizarAjusteControladoria && atividade !=  realizarAjusteGerenteRegional && atividade !=  realizarAjustePresidente && atividade !=  realizarAjusteDiretor && atividade != realizarAjusteContabil && atividade != analisePagamento && atividade != analiseContabil && atividade != realizarAnalisePagamento){
    	$("#formaPagamento").prop('disabled', true);
    	
    	
    	protege("#accordionCabecalhoEnvio")
        protege("#accordionListaNFEnvio")
        protege("#accordionNotasLancadas")
        protege("#accordionRateioNF")
        protege("#accordionAtivosNF")
        
    }
    
    if(atividade != AprovGestor && atividade != cobrarAtendimentoDemanda){
        protege("#accordionAreaGestor")
    }
    
    if(atividade != AprovGerenteRegional){
        protege("#accordionAreaGerRegional")
    }
    
    if(atividade != AprovPresidente){
        protege("#accordionAreaPresidente")
    }
    
    if(atividade != AprovDiretor){
        protege("#accordionAreaDiretoria")
    }
    
    
    if(atividade != analisarLancarNF && atividade != verificarAjustesEncerrarChamado){
        protege("#accordionLancaInputNF");
        protege("#accordionLancaWinthor");
        protege("#accordionCabecalho")
    }

    if(atividade != extraOrcamentario && atividade != extraOrcamentarioCentral){
        protege("#accordionAreaControladoria")
    }
       
    
    if(atividade != providenciarAjustes && atividade != providenciarAjustesAtraso){
        protege("#accordionAtendimento")
    }

    if(atividade != financeiro && atividade != canhotofinanceiro){
