        if($("#obsAtendimentoFin").val() != "" && $("#obsAtendimentoFin").val() != null){
        	$("#accordionFinanceiroDD").show();
        }else{
        	$("#accordionFinanceiroDD").hide();
        }
        //Presidente
        if($("#obsAreaPresidente").val() != "" && $("#obsAreaPresidente").val() != null){
            $("#accordionAreaPresidente").show();
        }else{
        	$("#accordionAreaPresidente").hide();
        }
        
        //Gerente Regional
        if($("#obsAreaGerRegional").val() != "" && $("#obsAreaGerRegional").val() != null){
            $("#accordionAreaGerRegional").show();
        }else{
        	$("#accordionAreaGerRegional").hide();
        }
        //Contabil
        if($("#obsAreaContabil").val() != "" && $("#obsAreaContabil").val() != null){
            $("#obsAreaContabil").show();
        }else{
        	$("#obsAreaContabil").hide();
        }
        
        
       
    }
    
    
    
    
    
    if(atividade == fim){
        if($("#obsInput").val() != "" && $("#obsInput").val() != null){
            $("#accordionInput").show()
        }
        
        $("#accordionAtendimento").show();
        
        $("#buttonRateio").hide();
        
        $("[id^=centroCustoRateio___]").attr('readonly', true);
        $("[id^=valorRateio___]").attr('readonly', true);

        
        
        if($("#obsGestor").val() != "" && $("#obsGestor").val() != null){
            $("#accordionGestor").show();
        }
        
        if($("#obsAtendimentoFin").val() != "" && $("#obsAtendimentoFin").val() != null){
            $("#accordionFinanceiroDD").show();
        }else{
        	$("#accordionFinanceiroDD").hide();
        }
        
        
        if($("#NumLancW").val() != "" && $("#NumLancW").val() != null){
            $("#accordionLancaWinthor").show();
        }else{
            $("#accordionLancaWinthor").hide();
        }
        
        if($("#obsAreaGestor").val() != "" && $("#obsAreaGestor").val() != null){
            $("#accordionAreaGestor").show()
        }else{
        	$("#accordionAreaGestor").hide()
        }
        
        if($("#obsAreaDiretoria").val() != "" && $("#obsAreaDiretoria").val() != null){
            $("#accordionAreaDiretoria").show();
        }else{
        	$("#accordionAreaDiretoria").hide();
        }
        if($("#obsAreaControladoria").val() != "" && $("#obsAreaControladoria").val() != null){
        	$("#accordionAreaControladoria").show();
        }else{
        	$("#accordionAreaControladoria").hide();
        }
        
        if($("#obsAtendimentoFin").val() != "" && $("#obsAtendimentoFin").val() != null){
            $("#accordionFinanceiroDD").show();
        }else{
        	$("#accordionFinanceiroDD").hide();
        }
        
        if($("#obsAtendimentoFin").val() != "" && $("#obsAtendimentoFin").val() != null){
        	$("#accordionFinanceiroDD").show();
        }else{
        	$("#accordionFinanceiroDD").hide();
        }
        
        //Presidente
        if($("#obsAreaPresidente").val() != "" && $("#obsAreaPresidente").val() != null){
            $("#accordionAreaPresidente").show();
        }else{
        	$("#accordionAreaPresidente").hide();
        }
        
        //Gerente Regional
        if($("#obsAreaGerRegional").val() != "" && $("#obsAreaGerRegional").val() != null){
            $("#accordionAreaGerRegional").show();
        }else{
        	$("#accordionAreaGerRegional").hide();
        }
        //Contabil
        if($("#obsAreaContabil").val() != "" && $("#obsAreaContabil").val() != null){
            $("#obsAreaContabil").show();
        }else{
        	$("#obsAreaContabil").hide();
        }

        
    }

}

function protege(div){
    $(div).find("input[type='text'],textarea").attr("readonly",true)
    $(div).find("input[type='radio']").attr("onclick",'return false')
    $(div).find("input[type='checkbox']").attr("onclick",'return false')

    setTimeout(function(){ 
        $(div).find("select[type='zoom']").each(function(){
            window[$(this).attr("id")].disable(true)
        })
     }, 1000);
    


     $(div).find("button").attr("disabled",true)
}

