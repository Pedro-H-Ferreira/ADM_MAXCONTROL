		    var saldoAtual = totalCONSINCO - totalFLUIG;
		        
		    // Arredonda para 2 casas para evitar erros como 100.000000001
		    saldoAtual = parseFloat(saldoAtual.toFixed(2));
		        
		   console.log("Saldo Calculado: " + saldoAtual);
