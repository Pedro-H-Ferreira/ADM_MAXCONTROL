		function showProfile(alias) {
			openURL(this.defaultURL() + "/profile/" + alias);
		}

		function showAlerts(alias) {
			openURL(this.defaultURL() + "/alerts/" + alias);
		}

		function showSocialDocs(alias) {
			openURL(this.defaultURL() + "/socialdocs/" + alias);
		}

		function showSearch(text, newTab) {
			openURL(this.defaultURL() + "/searchresult?text=" + encodeURIComponent(preventXSS(text)), newTab);
		}

		function showPost(alias, postId) {
			openURL(this.defaultURL() + "/post/" + alias + "/" + postId);
		}

		function openURL(url, newTab) {
			if (ctrlPressed || newTab) {
				window.open(url);
			} else {
				window.location.href = url;
			}
		}

		function confirm(msg, cbYes, cbNo, title) {

			var obj = $("<div style='display:none'>" + msg + "</div>"), titleYes = translations[cl()].titleYes, titleNo = translations[cl()].titleNo;

			obj.css("z-index", WCMAPI.getZIndex() + 1);
			$('body').append(obj);

			var options = {
				buttons: [{
					text: titleYes,
					click: function () {
						if (cbYes) {
							cbYes();
							$(obj).dialog('close');
						}
					}
				}, {
					text: titleNo,
					click: function () {
						if (cbNo) {
							cbNo();
						}
						$(obj).dialog('close');
					}
				}]
			};

			if (title) {
				options.title = title;
			}

			obj.dialog(options);
		}

		function alert(msg, cb) {
			var obj = $("<div style='display:none'>" + msg + "</div>")
				// , titleOk = "${i18n.getTranslation('label.system.ok')}";
				, titleOk = translations[cl()].titleOk;

			$('body').append(obj);
			obj.css("z-index", WCMAPI.getZIndex() + 1);

			obj.dialog({
				buttons: [{
					text: titleOk,
					click: function () {
						if (cb) {
							cb();
						}
						$(obj).dialog('close');
					}
				}]
			});
		};

		/*
		 * options = { type: '', //error, warning, info, success text: '', timeout: 1000 // milissegundos }
		 */
		function showLoading(options) {
			var labelLoading, msgType = 'message-', obj, msgClass = 'social-ecm-message';

			if (!options) {
				options = {};
				msgClass = 'social-ecm-loading';
			}

			labelLoading = options.text || translations[cl()].labelLoading;

			msgType += options.type || 'warning';

			obj = $("<div class='" + msgClass + " hidden'><p class='" + msgType + "'>" + labelLoading + "</p></div>");
			obj.css("z-index", WCMAPI.getZIndex() + 1);

			if (!$("#social-ecm-loading").length) {
				$('body').append(obj);
				obj.stop(true, true).fadeIn("fast");
			}

			if (options.timeout) {
				setTimeout(hideMessage, options.timeout);
			}
		};

		function hideLoading() {
			var msgClass = '.social-ecm-loading';

			$(msgClass).stop(true, true).fadeOut("fast", function () {
				$(this).remove();
			});
		};

		function hideMessage() {
			var msgClass = '.social-ecm-message';

			$(msgClass).stop(true, true).fadeOut("fast", function () {
				$(this).remove();
			});
		};

		function getSocialUser() {
			if (!socialUser) {
				socialUser = SocialAPI.SocialService.FINDSOCIAL({
					async: false
				}, '').content;
			}
			return socialUser;
		};

		function ev(sel, options, evName) {
			if (evName && cachedEvents[evName]) {
				// evento ja existe
				return;
			}

			if (typeof options === 'function') {
				$(document).on('click', sel, function (ev) {
					ev.preventDefault();
					options.call(this, ev);
				});

				cachedEvents[evName] = {
					events: 'click',
					sel: sel,
					parent: document
				};

				return;
			}

			if (!options) {
				options = {};
			}

			if (!options.parent) {
				options.parent = document;
			}

			if (!options.events) {
				options.events = 'click';
			}

			if (!options.fn) {
				options.fn = function (ev) {
				};
			}

			// saves the event config
			var eventName = options.eventName || evName;
			if (eventName) {
				// se ja havia sido bindado, nao faz de novo
				if (cachedEvents[eventName]) {
					return;
				}

				cachedEvents[eventName] = {
					events: options.events,
					sel: sel,
					parent: options.parent
				};
			}

			$(options.parent).on(options.events, sel, function (ev) {
				if (!options.doDefault) {
					ev.preventDefault();
				}

				options.fn.call(options.scope || this, ev);
			});
		}

		function removeEv(eventName) {
			var ev = cachedEvents[eventName];
			if (ev) {
				$(ev.parent).off(ev.events, ev.sel);
				delete cachedEvents[eventName];
			}
		}

		function socialShare(sociableId, shareType, dialogClass, linkUrl, cb) {
			var title = translations[cl()].titleModalShare, widgetsParams, zIndex;

			if (dialogClass) {
				dialogClass = dialogClass + ' w-fixed';
			} else {
				dialogClass = 'w-fixed';
			}

			// Garantir que o sociableId seja um INT.
			sociableId = parseInt(sociableId);

			widgetsParams = {
				"objectId": sociableId,
				"shareType": shareType,
				"linkUrl": linkUrl
			};

			WCMAPI.convertFtlAsync('socialshareapi', 'view.ftl', widgetsParams, function (html) {
				$(html).dialog({
					title: title,
					dialogClass: dialogClass,
					width: 660,
					open: function () {
						// Bug de z-index no firefox. Se colocar um número muito
						// alto de z-index, os inputs, buttons etc ficam indisponíveis.
						if ($(".wcm-panel").length) {
							zIndex = $(".wcm-panel").css("z-index");
							zIndex = parseInt(zIndex) + 1;
							$(this).parents('.ui-dialog').css({
								zIndex: zIndex
							});
						}
					},
					close: function () {
						$(this).remove();
					}
				});

				if (cb) {
					cb(null, html);
				}
			}, function (err) {
				socialGlobal.message({
					text: translations[cl()].errorModalShare,
					type: 'error',
					timeout: 2000
				});

				if (cb) {
					cb(err);
				}
			});
		}

		function socialWatch(widgetParams, titleModal, cb) {
			var title = translations[cl()].titleModalWatch;

			if (titleModal) {
				title = titleModal;
			}

			WCMAPI.convertFtlAsync('socialwatch', 'view.ftl', widgetParams, function (html) {
				$(html).dialog({
					title: title,
					dialogClass: 'w-fixed',
					height: 400,
					width: 400
				});

				if (cb) {
					cb(null, html);
				}
			}, function (err) {
				socialGlobal.message({
					text: translations[cl()].errorModalWatch,
					type: 'error',
					timeout: 2000
				});

				if (cb) {
					cb(err);
				}
			});
		}

		function socialLike(widgetParams, titleModal, cb) {
			var title = translations[cl()].titleModalLike;

			if (titleModal) {
				title = titleModal;
			}

			WCMAPI.convertFtlAsync('sociallike', 'view.ftl', widgetParams, function (html) {
				$(html).dialog({
					title: title,
					dialogClass: 'w-fixed',
					height: 400,
					width: 400
				});

				if (cb) {
					cb(null, html);
				}
			}, function (err) {
				socialGlobal.message({
					text: translations[cl()].errorModalLike,
					type: 'error',
					timeout: 2000
				});

				if (cb) {
					cb(err);
				}
			});
		}

		function onSocketReady(cb) {
			// se a socket ja existe, chama o callback com ela como parametro
			if (socket) {
				cb(socket);
			} else {
				socketReadyCallbacks.push(cb);
			}
		}

		function getDOMElement(classname, iid) {
			var fullcn = classname + '_' + iid, $el = $('.' + fullcn);

			if (!$el.length) {
				$('body').append("<div class='" + fullcn + "'></div>");
			}

			return $('.' + fullcn);
		}

		function findSocial(params) {
			if ($("#socialFinderContainer").empty()) {
				$("body").append("<div id='socialFinderContainer'></div>");
			}
			this.findSocialCallback = params.callback;
			var data = params.data || {};
			$("#socialFinderContainer").html(WCMAPI.convertFtl('socialfinder', 'finder.ftl', data));
			$("#socialFinderContainer").dialog({
				"title": params.title,
				"width": 600,
				"height": 600,
				close: function (event, ui) {
					$('#socialFinderContainer').remove();
				}
			});
			loadWidgets();
		}

		function findSocialsFavoriteRelatedPriorityForMention(pattern, callback) {

			var patternQuery = pattern.replace(/[-'`~!@#$%^&*()_|+=?;:'",.<>\{\}\[\]\\\/]/gi, '');
			// mention don't use solr for improve the speed in search
			var options = {
				url: '/api/public/social/share/list/socialstoshare?pattern=' + patternQuery,
				contentType: 'application/json',
				dataType: 'json',
				data: {
					limit: 10,
					offset: 0
				}
			};

			$.ajax(options).done(function (data) {
				callback(data);
			}).fail(function (xhr, status, text) {
				FLUIGC.toast({
					message: translations[cl()].error,
					type: 'danger'
				});
			});
		}

		function findSocialsFavoriteRelatedPriority(pattern, types, callback) {

			var patternQuery = '&pattern=' + pattern.replace(/[-'`~!@#$%^&*()_|+=?;:'",.<>\{\}\[\]\\\/]/gi, '');
			var typesQuery = '';

			for (typeIndex in types) {
				typesQuery = typesQuery + '&types=' + types[typeIndex];
			}

			$.ajax({
				url: SocialAPI.SearchService.SEARCHSOCIALWITHFAVORITEANDRELATEDPRIORITY__PATH() + '?' + patternQuery
					+ typesQuery,
				dataType: 'json',
				success: function (data) {
					if (callback) {
						callback(data);
					}
				},
				error: function () {
					alert('Error');
				}
			});
		}

		function suggestTags(pattern, limit, callback) {
			var patternQuery = '?pattern=' + pattern.replace(/[-'`~!@#$%^&*()_|+=?;:'",<>\{\}\[\]\\\/]/gi, '');
			var limitQuery = '&limit=' + limit;
			$.ajax({
				url: SocialAPI.TagSearchServiceRest.SUGGESTTAGS__PATH() + patternQuery + limitQuery,
				dataType: 'json',
				success: function (data) {
					if (callback) {
						callback(data);
					}
				},
				error: function () {
					alert('Error');
				}
			});
		}

		function findSocialCallback() {
		}

		function mentionsInput(element, elastic, onSelect) {

			// Verificar se o plugin mentionsInput foi adicionado na pagina.
			if ($.fn.mentionsInput !== undefined) {
				var labelUser = translations[cl()].labelUser, labelCommunity = translations[cl()].labelCommunity, triggerCharTMP = null;

				if (elastic === undefined) {
					elastic = true;
				}

				var triggerChar = $(element).data('type-input');

				if (triggerChar && triggerChar === 'tag') {
					triggerCharTMP = ['#'];
				} else if (triggerChar && triggerChar === 'mention') {
					triggerCharTMP = ['@'];
				} else {
					triggerCharTMP = ['@', '#'];
				}

				$(element)
					.mentionsInput(
					{
						triggerChar: triggerCharTMP,
						elastic: elastic,
						minChars: 0,
						templates: {
							autocompleteListItem: _
								.template('<li data-ref-id="<%= id %>" data-ref-alias="<%= alias %>" data-ref-type="<%= type %>" data-display="<%= display %>"><span><%= content %></span><div class="mention-user-type <%= newClass %>" data-new="['
								+ translations[cl()].labelNewTag + ']"><%= type %></div></li>'),
							autocompleteListItemAvatar: _
								.template('<div class="mention-container-avatar"><img src="<%= avatar %>" /></div>'),
							mentionItemSyntax: _.template('@[<%= alias %>]'),
							hashTagItemSyntax: _.template('<%= value %>'),
						},
						onSelectData: function (event) {
							if (onSelect) { onSelect(event); }
						},
						onDataRequest: function (mode, query, fun, triggerChar) {
							mentionsRequestQuery = query;
							clearTimeout(timeoutMentionsInput);
							timeoutMentionsInput = setTimeout(function () {
								if (triggerChar == '@') {
									findSocialsFavoriteRelatedPriorityForMention(query, function (data) {
										if (query === mentionsRequestQuery) {
											var obj = data.content, len = obj.length, i = 0, labelType;
											for (i; i < len; i++) {
												labelType = (obj[i].type === 'USER') ? labelUser : labelCommunity;
												obj[i].avatar = '/social/api/rest/social/imagetype/' + obj[i].type
													+ '/thumb/' + obj[i].alias;
												obj[i].type = labelType;
											}
											fun.call(this, obj);
										}
									});
								} else if (triggerChar == '#') {
									if (query.length > 1) {
										query = query.replace(/(\s)(\w+)/g, '');
										suggestTags(query, 5, function (data) {
											if (query === mentionsRequestQuery) {
												var result = [], obj = [], hasItemQuery = false;
												data.items.forEach(function (item, idx) {
													for (field in item.fields) {
														result = result.concat(item.fields[field]);
													}
												});
												for (var i in result) {
													obj[i] = {
														name: '#' + result[i],
														type: 'tag'
													};
													if (query === result[i]) {
														hasItemQuery = true;
													}
												}
												if (obj.length < 1 || !hasItemQuery) {
													obj.push({
														name: '#' + query,
														type: 'tag',
														newClass: 'new-class'
													});
												}
												fun.call(this, obj);
											}
										});
									}
								}
							}, 200);
						}
					});
			}
		}

		function showCardPopover(selector) {

			// Verificar se o plugin popover foi adicionado na pagina.
			if ($.fn.totvsPopover !== undefined) {
				var elSelector = '[data-user-popover]';

				if (selector) {
					elSelector = selector + ' [data-user-popover]';
				}

				$(elSelector).totvsPopover({
					popoverPosition: 'auto',
					startDelay: 600,
					endDelay: 200,
					fadeIn: 120,
					width: 380,
					height: 194,
					subTop: 60,
					calcHeight: 194,
					calcWidth: 380,
					onMouseEnter: function (el, ev) {
						var alias = $(el).children('[data-user-popover]').attr('data-user-popover');
						if (!$(el).find('.totvs-popover .widget-card-user').length) {
							$(el).addClass('loading');
							loadCardPopover(el, ev, alias);
						}
					},
					onMouseLeave: function (el, ev) {
						$(el).find('.totvs-popover .widget-card-user').remove();
					}
				});
			}
		}

		function loadCardPopover(el, ev, alias) {
			var params = {
				aliasPage: alias,
				cardPopover: true,
				instanceIdPopover: (new Date().getTime()).toString()
			};

			WCMAPI.convertFtlAsync('socialcard', 'view.ftl', params, function (html) {
				$(el).removeClass('loading');
				$(el).find('.wrapper-popover').append(html);
				loadFavorites();
			});
		}

		function preventXSS(str) {
			return str.replace(/<|>/gi, '');
		}

		return {
			addEvent: ev,
			alert: alert,
			confirm: confirm,
			defaultURL: defaultURL,
			getSocialUser: getSocialUser,
			hideLoading: hideLoading,
			hideMessage: hideMessage,
			loadSociables: loadSociables,
			loadFavorites: loadFavorites,
			onSocketReady: onSocketReady,
			removeEvent: removeEv,
			share: socialShare,
			showAlerts: showAlerts,
			showSocialDocs: showSocialDocs,
			showCommunities: showCommunities,
			showCommunity: showCommunity,
			showUser: showUser,
			showConnections: showConnections,
			showFollowers: showFollowers,
			showFollowings: showFollowings,
			showGalleries: showGalleries,
			showGallery: showGallery,
			showHome: showHome,
			showLoading: showLoading,
			message: showLoading,
			showMedia: showMedia,
			showParticipations: showParticipations,
			showPost: showPost,
			showProfile: showProfile,
			showSearch: showSearch,
			showSocial: showSocial,
			getDOMElement: getDOMElement,
			findSocial: findSocial,
			findSocialsFavoriteRelatedPriority: findSocialsFavoriteRelatedPriority,
			findSocialsFavoriteRelatedPriorityForMention: findSocialsFavoriteRelatedPriorityForMention,
			suggestTags: suggestTags,
			findSocialCallback: findSocialCallback,
			watchUsersList: socialWatch,
			likeUsersList: socialLike,
			mentionsInput: mentionsInput,
			showCardPopover: showCardPopover,
			getAliasCommunityPage: getAliasCommunityPage
		};
	})(window, document);
}
