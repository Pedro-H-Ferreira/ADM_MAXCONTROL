		function showSocial(alias) {
			var social = SocialAPI.SocialService.FINDSOCIALBYALIAS({
				async: false
			}, alias).content;
			if (social.type == 'COMMUNITY') {
				this.showCommunity(alias, social.customPage);
			} else {
				this.showUser(alias);
			}
		}

		function showUser(alias) {
