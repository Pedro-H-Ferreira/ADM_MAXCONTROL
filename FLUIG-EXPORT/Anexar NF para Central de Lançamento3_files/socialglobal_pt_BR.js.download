		$(document).ready(function () {
			init();
		});

		function init() {
			loadSociables();
			loadFavorites();
			globalEvents();
			initSocket();
		}

		function initSocket() {
			var curPageCode = WCMAPI.getPageCode();
			pageBlackList = isPageBlackList(curPageCode);
			nodeEnabled = isNodeEnabled();

			// O realtime não é carregado quando estiver
			// dentro do app nativo do fluig.
			if (!WCMAPI.isMobileAppMode() && (nodeEnabled && !pageBlackList)) {
				// import soket.io API
				var s = document.createElement('script');
				s.src = socketURL + "/socket.io/socket.io.js";
				s.type = "text/javascript";
				s.async = true;
				s.defer = true;

				document.body.appendChild(s);

				$(s).on('load', function () {
					socketLoaded();
				});

				$(s).on('error', function (err) {
					socketLoadError();
				});
			}
		}

		function isNodeEnabled() {
			try {
				return true;
			} catch (e) {
				return false;
			}
		}

		function isPageBlackList(curPageCode) {
			return blackListPagesSocket.indexOf(curPageCode) !== -1;
		}

		function cl() {
			return WCMAPI.getLocale().toUpperCase();
		}

		function getSourceImage(profileType, alias, size) {
			var parameterType;

			switch (profileType) {
				case 'COMMUNITY':
					parameterType = 'communities';
					break;
				case 'USER':
				default:
					parameterType = 'users';
					break;
			}

			return "/collaboration/api/v3/" + parameterType + "/" + alias + "/picture?type=" + size + "&time=" + Date.now();
		}

		function updateImageProfile(ev, alias) {
			var userAlias = alias || WCMAPI.getUserLogin(),
				listOfImgElements = $('[data-update-image-profile]'),
				profileType,
				size,
				src;

			listOfImgElements.map(function (index, selector) {
				image = $(selector);
				userAlias = image.attr('data-update-image-profile');
				profileType = image.attr('data-profile-type');
				size = image.attr('data-image-size');
				src = getSourceImage(profileType, userAlias, size);
				image.attr('src', src);
			});
		}

		function globalEvents() {
			$(window).click(function (evt) {
				ctrlPressed = false;

				if (evt.metaKey || evt.ctrlKey || evt.button == 1) {
					ctrlPressed = true;
				};
			});

			$(window).on(
				'fluig.update.image.profile',
				updateImageProfile
			);
		}

		function loadSociables() {
			$(".sociable-object-load").map(
				function (index, element) {
					var elementId, that, objectClass, objectId, style, params, moreicons;

					that = $(element);
					elementId = that.attr("id");
					objectClass = that.data("objectclass");
					objectId = that.data("objectid");
					showAllIds = that.data("showallids");
					linkUrl = that.data("link");
					style = that.data("style") || "DEFAULT";
					moreicons = that.data("moreicons");
					ommitLike = that.data("ommit-like") || false;
					ommitShare = that.data("ommit-share") || false;
					ommitComment = that.data("ommit-comment") || false;
					ommitWatch = that.data("ommit-watch") || false, contentType = that.data("content-type") || '',
						originUrl = that.data("origin-url") || '', previewTemplate = that.data("preview-template")
						|| '';

					if (showAllIds == null) {
						showAllIds = false;
					}

					params = {
						"social_obj_class": objectClass,
						"social_obj_id": objectId,
						"show_all_ids": showAllIds,
						"link_url": linkUrl,
						"style": style,
						"customInstance": (new Date().getTime()).toString(),
						ommitLike: ommitLike,
						ommitShare: ommitShare,
						ommitComment: ommitComment,
						ommitWatch: ommitWatch,
						contentType: contentType,
						originUrl: originUrl,
						previewTemplate: previewTemplate
					};

					WCMAPI.convertFtlAsync('sociable', 'view.ftl', JSON.stringify(params), function (data) {
						that.removeClass("sociable-object-load").html(data);
						if (moreicons) {
							moreicons = moreicons.replace(/\'/g, '\"').replace(/\{(\w+)/g, '\"$1\"').replace(/,(\w+)/g,
								',\"$1\"');
							var arrayIcon = [];
							try {
								arrayIcon = JSON.parse(moreicons);
								for (var i in arrayIcon) {
									if (arrayIcon[i].action) {
										$('#' + elementId + ' ul.sociable-more').append(
											'<li class="sociable-list-actions-item"><span class="counter-group"><a href="#" '
											+ arrayIcon[i].action + ' title="' + arrayIcon[i].title + '" class="'
											+ arrayIcon[i].cssclass
											+ '"></a><span class="counter counter-warning pos-right-bottom">'
											+ arrayIcon[i].value + '</span></span></li>');
									} else {
										$('#' + elementId + ' ul.sociable-more').append(
											'<li class="sociable-list-actions-item"><span class="counter-group"><span class="'
											+ arrayIcon[i].cssclass
											+ '"></span><span class="counter counter-warning pos-right-bottom">'
											+ arrayIcon[i].value + '</span></span></li>');
									}
								}
							} catch (e) {
							}
						}
						loadWidgets();
					});
				});
		}

		function loadFavorites() {
			$(".social-favorite-object-load").map(function (index, element) {
				var that, objectClass, objectId, style, params;

				that = $(element);
				alias = that.data("alias");

				params = {
					"style": "iconic",
					"alias": alias,
					"customInstance": (new Date().getTime()).toString()
				};

				WCMAPI.convertFtlAsync('socialfavorite', 'viewIconic.ftl', JSON.stringify(params), function (data) {
					that.removeClass("social-favorite-object-load").html(data);
					loadWidgets();
				});
			});
		}

		function getCookie(name) {
			var name = name + "=";
			var ca = document.cookie.split(';');
			for (var i = 0; i < ca.length; i++) {
				var c = ca[i];
				while (c.charAt(0) == ' ') { c = c.substring(1); }
				if (c.indexOf(name) == 0) {
					return c.substring(name.length, c.length);
				}
			}
			return "";
		}

		function socketLoaded() {
			var delayReconnect = 30000,
				polling = "false" == "true" && WCMAPI.isIe9();

			var options = {
				'timeout': 10000, // Quanto tempo em ms até que ele desiste de se conectar com um transporte. Padrão:
				// 20.000 (ms)
				'reconnection': false, // Se ele tentará se reconectar depois de ser desconectado. Padrão: true
				'reconnectionAttempts': 1,
				'forceNew': true,
				'transports': [polling ? 'polling' : 'websocket']
			};

			socket = io.connect(socketURL, options);

			var intervalID = 0;
			var reconnectCount = 0;

			socket.on('connect', function () {
				if (this.nsp == '/') {
					socket.emit('authenticate', { tenantId: WCMAPI.getTenantId(), login: WCMAPI.userLogin });
				} else {
					reconnectCount = 0;
				}
			});

			socket.on('authorized', function () {
				this.connected = false;
				this.nsp = '/tenant' + WCMAPI.getTenantId();
				this.connect();
			});

			socket.on('connecting', function () {
			});

			socket.on('disconnect', function (msg) {
				this.nsp = '/';
				if (intervalID == 0) {
					intervalID = setInterval(tryReconnect, delayReconnect);
				}
			});

			socket.on('connect_failed', function () {
			});

			socket.on('error', function (err) {
			});

			socket.on('reconnect_failed', function () {
			});

			socket.on('reconnect', function () {
				clearInterval(intervalID);
				intervalID = 0;
			});

			socket.on('reconnecting', function () {
			});

			// recebe os eventos para o usuario logado
			socket.on('RT_EVENT', function (data) {
				WCMAPI.fireEvent(data.eventName, data.data);
			});

			// itera os callbacks das widgets que querem usar a socket
			for (var i = 0; i < socketReadyCallbacks.length; i++) {
				socketReadyCallbacks[i](socket);
			}

			var tryReconnect = function () {
				++reconnectCount;
				if (reconnectCount == 5) {
					clearInterval(intervalID);
				} else {
					socket.io.reconnect();
				}
			};

			if (WCMAPI.isIe9()) {
				$(window).bind('beforeunload', function () {
					if (socket && socket.connected) {
						socket.disconnect();
					}
				});
			}
		}

		function socketLoadError() {
			console.warn('%c' + translations[cl()].realtimeServiceError, 'color: #F36F21; font-weight: bold; font-size: 12px');
		}

		function defaultURL() {
			return WCMAPI.getContextPath() + "/p/" + WCMAPI.getTenantCode();
		}

		/*
		 * If is a community page return alias community if no return null
		 */
		function getAliasCommunityPage() {
			if (WCMAPI.getParentPageCode() === "subject") {
				return WCMAPI.getPageCode();
			}

			return null;
		}

