				labelNewTag: 'Nuevo',
				error: "Houve um erro ao executar a ação",
				realtimeServiceError: 'Si usted está viendo el error \'net::ERR_CONNECTION_REFUSED\', por favor verifique el estado del servicio fluig_Realtime! \nPara más información acceda: http://tdn.totvs.com/pages/viewpage.action?pageId=287049626'
