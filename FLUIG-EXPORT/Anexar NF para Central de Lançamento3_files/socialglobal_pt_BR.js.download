				realtimeServiceError: 'If you are getting \'net::ERR_CONNECTION_REFUSED\' error, please check the status of fluig_Realtime service! \nFor more information you can access our FAQ: http://tdn.totvs.com/pages/viewpage.action?pageId=287049626'
			}
		};

		var timeoutMentionsInput = null;
		var mentionsRequestQuery = '';
		var socket;
		var nodeEnabled;
		var pageBlackList;
		var socketURL = window.location.protocol + "//nossaempresa.fluig.cloudtotvs.com.br";
		var socialUser = null;
		var cachedEvents = {};
		var ctrlPressed = false;
