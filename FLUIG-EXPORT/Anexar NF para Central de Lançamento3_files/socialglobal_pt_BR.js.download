		function showFollowings(alias) {
			openURL(this.defaultURL() + "/connections/" + alias + "/followings");
		}

		function showFollowers(alias) {
			openURL(this.defaultURL() + "/connections/" + alias + "/followers");
		}

		function showParticipations(alias) {
			openURL(this.defaultURL() + "/connections/" + alias + "/participations");
