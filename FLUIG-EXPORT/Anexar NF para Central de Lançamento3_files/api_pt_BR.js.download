function WCMDATAAPI(){}
function WCMDATAAPI_PermissionService(){}
WCMDATAAPI_PermissionService.prototype.basePath = function(){
return "/portal/api/rest/wcm/permission";}
WCMDATAAPI.prototype.ajaxCall = function(__httpMethod__, __callData, __cmdurl__, __datatype__, __contentType__, __postdata__){
var 	__ret__=null;
	jQuery.ajax( {
    	type : __httpMethod__ ,
    	async : __callData.async,
    	url : __cmdurl__ ,
    	dataType : __datatype__,
    	contentType: __contentType__ +"; charset=utf-8",
    	data: __postdata__,
    	success : function(response) {
if (      	__callData.async == false){
      	__ret__=response;
}else{
      	__callData.success.call(__callData.oObj, response, __callData);
}
    	},
    	error : function(XMLHttpRequest, textStatus, errorThrown) {
      	errorThrown=eval('('+XMLHttpRequest.responseText+')');
      	if (__callData.errorCallback) {
          	__callData.errorCallback.call(__callData.oObj, XMLHttpRequest, textStatus, errorThrown, __callData);
      	}else{
          	throw errorThrown;
    	}}
	});
if (	__callData.async == false){
    	return __ret__;
}
	}
WCMDATAAPI_PermissionService.prototype.SEARCHASSETSWITHPERMISSIONSBYFILTER__PATH = function(){
return "/portal/api/rest/wcm/permission"+"/searchAssetsWithPermissionsByFilter";}
WCMDATAAPI_PermissionService.prototype.SEARCHASSETSWITHPERMISSIONSBYFILTER = function(__callData,rows,offset,categoryId,category,categoryToReturn,filter){
var __cmdurl__="/portal/api/rest/wcm/permission"+"/searchAssetsWithPermissionsByFilter";
var __ret__=null;
WCMAPI.extendSession();
__cmdurl__+="?space=" + WCMAPI.getSpaceAlias() + "";
if (rows){
__cmdurl__+="&rows=";
__cmdurl__+=encodeURIComponent(rows);
}
if (offset){
__cmdurl__+="&offset=";
__cmdurl__+=encodeURIComponent(offset);
}
if (categoryId){
__cmdurl__+="&categoryId=";
__cmdurl__+=encodeURIComponent(categoryId);
}
if (category){
__cmdurl__+="&category=";
__cmdurl__+=encodeURIComponent(category);
}
if (categoryToReturn){
__cmdurl__+="&categoryToReturn=";
__cmdurl__+=encodeURIComponent(categoryToReturn);
}
if (filter){
__cmdurl__+="&filter=";
__cmdurl__+=encodeURIComponent(filter);
}
__ret__=WCMSpaceAPI.ajaxCall("GET", __callData, __cmdurl__, "application/json", "application/x-www-form-urlencoded", undefined);
    return __ret__;
}
