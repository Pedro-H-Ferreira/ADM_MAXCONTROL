$(function(){ECM.webdav={};ECM.webdav.editDocument=function(documentId,version,fileName){var url=ECM.restUrl+"documentPublisher/createTempFileWebdav/"+documentId+"/"+version;if(fileName){url+="?fileName="+fileName}WCMAPI.Read({url:url,success:function funcao(data){try{console.log("ecm-webdav: Resposta de publisher rest: "+data);WCMAPI.loadJS("/ecm_resources/resources/webdavAJAXLibrary/ITHitWebDAVClient.js");ITHit.WebDAV.Client.DocManager.EditDocument(data)}catch(e){WCMAPI.Create({url:ECM.restUrl+"documentView/cancelCheckOut/",data:{documentId:documentId},success:function(){FLUIGC.message.error({message:"Recurso não suportado! Verifique se o browser é homologado ou a instalação do MS Office."})}})}}})}});