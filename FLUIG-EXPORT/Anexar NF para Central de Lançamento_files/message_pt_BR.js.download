WCMC.message=function(){var message={};var wcmMessageInter=$("#wcm-message-inter");var lastShowMessage=new Date();var hideMileseconds=7000;var functions=$({showMessage:function(str){message.showMessage(str)}});if(wcmMessageInter.length===0){$("body").prepend('<div id="wcm-message-inter"><div id="wcm-message-content"><span id="wcm-message-msg" class="message-warning"></span></div></div>')}var wcmMessageContent=$("#wcm-message-content");var wcmMessageMsg=$("#wcm-message-msg");wcmMessageInter=$("#wcm-message-inter");message.showMessage=function(str){wcmMessageMsg.html(str);wcmMessageInter.css("z-index",WCMAPI.getZIndex());lastShowMessage=new Date();if(wcmMessageContent.css("display")==="none"){setTimeout(showMessage,250);setTimeout(hideMessage,hideMileseconds)}};function showMessage(){wcmMessageInter.css("z-index",WCMAPI.getZIndex());wcmMessageContent.fadeIn("slow");wcmMessageInter.animate({top:0},1000,"easeOutBounce")}function hideMessage(){var diferenceMileseconds=new Date()-lastShowMessage;if(diferenceMileseconds>hideMileseconds){wcmMessageContent.fadeOut("slow");wcmMessageInter.animate({top:"-35px"},1000,"easeOutBounce")}else{setTimeout(hideMessage,hideMileseconds-diferenceMileseconds)}}return functions[0]};